---
const {
  introLead = "Who is",
  introTail = "",
  introName = "Riad Mukhtarov",
  metaTitle = "Riad Mukhtarov — Portfolio",
  metaDescription = "Backend & Distributed Systems engineer building reliable, production‑ready, event‑driven systems.",
  metaImage = "https://r14dd.github.io/arch.webp",
  structuredData = "",
  lang = "en",
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang} translate="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google" content="notranslate" />
    <meta name="translate" content="no" />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://r14dd.github.io" />
    <meta property="og:image" content={metaImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />
    <link rel="canonical" href="https://r14dd.github.io" />
    {structuredData && <script type="application/ld+json" set:html={structuredData} />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline>
      if (localStorage.getItem('portfolio-theme') === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --bg: #050505;
        --text: #eeeeee;
        --text-soft: #a1a1a1;
        --muted: #888888;
        --accent: #c9a55a;
        --accent-rgb: 201, 165, 90;
        --border: rgba(255, 255, 255, 0.06);
        --surface: rgba(5, 5, 5, 0.6);
        --surface-solid: rgba(5, 5, 5, 0.75);
        --surface-panel: rgba(12, 12, 12, 0.9);
        --overlay: rgba(255, 255, 255, 0.06);
        --overlay-strong: rgba(255, 255, 255, 0.1);
        --shadow: rgba(0, 0, 0, 0.4);
        --shadow-strong: rgba(0, 0, 0, 0.55);
        --noise-opacity: 0.035;
        --card-hover: rgba(var(--accent-rgb), 0.025);
        --selection: rgba(var(--accent-rgb), 0.2);
        --marker: rgba(var(--accent-rgb), 0.45);
        --intro-solid: rgba(5, 5, 5, 0.95);
        --intro-semi: rgba(5, 5, 5, 0.7);
        color-scheme: dark;
      }

      html.light {
        --bg: #faf9f6;
        --text: #1a1a1a;
        --text-soft: #4a4a4a;
        --muted: #777777;
        --accent: #a8863d;
        --accent-rgb: 168, 134, 61;
        --border: rgba(0, 0, 0, 0.06);
        --surface: rgba(255, 255, 255, 0.7);
        --surface-solid: rgba(255, 255, 255, 0.85);
        --surface-panel: rgba(255, 255, 255, 0.95);
        --overlay: rgba(0, 0, 0, 0.04);
        --overlay-strong: rgba(0, 0, 0, 0.08);
        --shadow: rgba(0, 0, 0, 0.1);
        --shadow-strong: rgba(0, 0, 0, 0.15);
        --noise-opacity: 0.02;
        --card-hover: rgba(var(--accent-rgb), 0.06);
        --selection: rgba(var(--accent-rgb), 0.25);
        --marker: rgba(var(--accent-rgb), 0.6);
        --intro-solid: rgba(250, 249, 246, 0.95);
        --intro-semi: rgba(250, 249, 246, 0.7);
        color-scheme: light;
      }

      * {
        box-sizing: border-box;
      }

      :focus-visible {
        outline: 2px solid rgba(var(--accent-rgb), 0.6);
        outline-offset: 3px;
        border-radius: 4px;
      }

      .skip-link {
        position: fixed;
        top: -100%;
        left: 1rem;
        z-index: 9999;
        padding: 0.6rem 1.2rem;
        background: var(--bg);
        color: var(--accent);
        border: 1px solid rgba(var(--accent-rgb), 0.3);
        border-radius: 8px;
        font-size: 0.9rem;
        text-decoration: none;
        transition: top 0.2s ease;
      }

      .skip-link:focus {
        top: 1rem;
      }

      html {
        background: var(--bg);
      }

      body {
        background: var(--bg);
        color: var(--text-soft);
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 0;
        padding: 3rem 1.5rem 4rem;
        line-height: 1.8;
        font-size: 16px;
      }

      .content {
        max-width: 840px;
        margin: 0 auto;
      }

      .content,
      .side-nav,
      .side-links,
      .mobile-bar,
      .lang-switcher {
        transition: opacity 0.2s ease;
      }

      body.lang-switching .content,
      body.lang-switching .side-nav,
      body.lang-switching .side-links,
      body.lang-switching .mobile-bar,
      body.lang-switching .lang-switcher {
        opacity: 0;
        pointer-events: none;
      }

      h1 {
        font-size: clamp(1.8rem, 5vw, 2.6rem);
        margin: 0 0 0.4rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
        background: linear-gradient(90deg, var(--text) 0%, var(--accent) 35%, var(--text) 55%, var(--text) 100%);
        background-size: 250% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: name-shimmer 6s linear infinite;
      }

      @keyframes name-shimmer {
        0%   { background-position: 200% center; }
        100% { background-position: -200% center; }
      }

      h2 {
        font-size: 1.45rem;
        margin: 0 0 1rem 0;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--text);
      }

      h3 {
        font-size: 1rem;
        margin: 0.7rem 0 0.4rem 0;
        font-weight: 500;
        color: var(--text);
      }

      section {
        padding: 0;
        margin: 5rem 0 0;
      }

      section:first-of-type {
        margin-top: 2.5rem;
      }

      .lang-switcher {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 200;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .theme-toggle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: 1px solid rgba(var(--accent-rgb), 0.12);
        background: var(--surface);
        backdrop-filter: blur(10px);
        color: var(--accent);
        font-size: 1.05rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition: box-shadow 0.25s ease, border-color 0.25s ease, transform 0.15s ease;
      }

      .theme-toggle:hover {
        border-color: rgba(var(--accent-rgb), 0.3);
        box-shadow: 0 0 18px rgba(var(--accent-rgb), 0.15);
      }

      .lang-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid rgba(var(--accent-rgb), 0.12);
        background: var(--surface);
        color: var(--accent);
        font-size: 0.92rem;
        backdrop-filter: blur(10px);
        cursor: pointer;
        transition: box-shadow 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
      }

      .lang-toggle:hover {
        border-color: rgba(var(--accent-rgb), 0.3);
        box-shadow: 0 0 18px rgba(var(--accent-rgb), 0.15);
      }

      .lang-globe {
        font-size: 1.05rem;
      }

      .lang-caret {
        opacity: 0.7;
      }

      .lang-menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 0;
        display: none;
        flex-direction: column;
        min-width: 180px;
        padding: 0.5rem;
        border-radius: 16px;
        background: var(--surface-panel);
        border: 1px solid var(--overlay);
        backdrop-filter: blur(12px);
        box-shadow: 0 16px 40px var(--shadow);
      }

      .lang-switcher.open .lang-menu,
      .lang-menu.open {
        display: flex;
      }

      .lang-menu button {
        background: transparent;
        border: none;
        color: var(--text-soft);
        text-align: left;
        padding: 0.5rem 0.65rem;
        border-radius: 10px;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease;
      }

      .lang-menu button:hover {
        background: var(--overlay);
        color: var(--text);
      }

      body.intro-done .lang-toggle {
        animation: lang-glow 1.8s ease-in-out 0.3s;
      }

      @keyframes lang-glow {
        0% { box-shadow: 0 0 0 rgba(var(--accent-rgb), 0); }
        50% { box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.25); }
        100% { box-shadow: 0 0 0 rgba(var(--accent-rgb), 0); }
      }

      p {
        margin-top: 0.6rem;
        color: var(--text-soft);
      }

      small {
        display: block;
        margin-bottom: 0.6rem;
        color: var(--muted);
      }

      ul {
        padding-left: 1.2rem;
        margin-top: 0.6rem;
      }

      li {
        margin-bottom: 0.4rem;
        color: var(--text-soft);
      }

      li::marker {
        color: var(--marker);
      }

      code {
        background: var(--overlay);
        border: 1px solid var(--overlay-strong);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        color: var(--text);
        font-size: 0.88em;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      }

      strong {
        color: var(--text);
      }

      em {
        color: var(--muted);
        font-style: italic;
      }

      a {
        color: var(--text);
        text-decoration: none;
        background-image: linear-gradient(rgba(var(--accent-rgb), 0.5), rgba(var(--accent-rgb), 0.5));
        background-size: 0% 1px;
        background-position: left bottom;
        background-repeat: no-repeat;
        transition: background-size 0.3s ease, opacity 0.2s ease;
      }

      a:hover {
        background-size: 100% 1px;
        opacity: 0.85;
      }

      ::selection {
        background: var(--selection);
        color: var(--text);
      }

      .page-intro {
        position: fixed;
        inset: 0;
        background: var(--bg);
        z-index: 999;
        pointer-events: none;
        overflow: hidden;
        display: grid;
        place-items: center;
        perspective: 1200px;
        animation: intro-exit 1.4s ease forwards;
      }

      .intro-phrase {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--accent);
        font-size: clamp(1rem, 3vw, 1.4rem);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        opacity: 0;
        transition: opacity 0.15s ease;
      }

      .intro-phrase .lead {
        opacity: 0.55;
        font-weight: 400;
      }

      body.intro-ready .intro-phrase {
        opacity: 1;
      }

      .intro-name {
        display: inline-flex;
        gap: 0.12em;
        transform-style: preserve-3d;
        position: relative;
        font-weight: 700;
      }

      .intro-name span {
        display: inline-block;
        opacity: 0;
        transform: translateZ(40px) rotateX(-30deg);
        animation: letter-in 0.7s ease forwards;
      }

      @keyframes letter-in {
        0% { opacity: 0; transform: translateZ(40px) rotateX(-30deg); }
        100% { opacity: 1; transform: translateZ(0px) rotateX(0deg); }
      }

      @keyframes intro-exit {
        0% { opacity: 1; visibility: visible; }
        85% { opacity: 1; visibility: visible; }
        100% { opacity: 0; visibility: hidden; }
      }

      .intro-bricks {
        position: fixed;
        inset: 0;
        z-index: 998;
        pointer-events: none;
        background:
          linear-gradient(90deg, var(--intro-solid) 50%, var(--intro-semi) 50%),
          linear-gradient(0deg, var(--intro-solid) 50%, var(--intro-semi) 50%);
        background-size: 48px 32px;
        opacity: 1;
        animation: bricks-reveal 0.9s ease forwards 1.1s;
      }

      @keyframes bricks-reveal {
        0% { opacity: 1; }
        100% { opacity: 0; }
      }

      section {
        opacity: 0;
        transform: translateX(-18px);
        transition: transform 0.7s ease, opacity 0.7s ease;
      }

      section:nth-of-type(even) {
        transform: translateX(18px);
      }

      section.section-revealed {
        opacity: 1;
        transform: translateX(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .page-intro,
        .intro-bricks {
          display: none !important;
        }

        .intro-name span,
        .intro-name,
        .intro-phrase {
          animation: none !important;
          transform: none !important;
          opacity: 1 !important;
        }

        section {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }

        .project-card,
        .meta-card {
          transform: none !important;
          transition: none !important;
        }

        .project-card::before,
        .meta-card::before,
        .section-revealed h2::after {
          display: none !important;
        }

        .section-revealed .project-card,
        .section-revealed .meta-card,
        .section-revealed .reading-row {
          opacity: 1 !important;
          transform: none !important;
          animation: none !important;
        }

        .section-revealed ul li {
          opacity: 1 !important;
          transform: none !important;
          animation: none !important;
        }

        .cursor-dot { display: none !important; }
      }

      footer {
        margin-top: 4rem;
        padding-top: 2rem;
        text-align: center;
        font-size: 0.75rem;
        color: var(--muted);
        border-top: 1px solid rgba(var(--accent-rgb), 0.1);
      }

      .section-block {
        padding-top: 1rem;
        border-top: 1px solid rgba(var(--accent-rgb), 0.1);
        margin-top: 3.2rem;
      }

      .side-nav {
        position: fixed;
        left: 2.5rem;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        padding: 0.8rem 1rem;
        background: var(--surface);
        border: 1px solid rgba(var(--accent-rgb), 0.08);
        border-radius: 12px;
        backdrop-filter: blur(10px);
        z-index: 10;
      }

      .side-nav a {
        border-bottom: none;
        background-image: none;
        color: var(--text-soft);
        font-size: 0.85rem;
        transition: color 0.2s ease, opacity 0.2s ease, transform 0.15s ease;
      }

      .side-nav a.active {
        color: var(--accent);
      }

      .side-nav.blurred {
        background: var(--surface-solid);
        backdrop-filter: blur(14px);
      }

      .side-links {
        position: fixed;
        right: 2.5rem;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        padding: 0.8rem 1rem;
        background: var(--surface);
        border: 1px solid rgba(var(--accent-rgb), 0.08);
        border-radius: 12px;
        backdrop-filter: blur(10px);
        z-index: 10;
      }

      .side-links a {
        border-bottom: none;
        background-image: none;
        color: var(--text-soft);
        font-size: 0.85rem;
        transition: color 0.2s ease, opacity 0.2s ease, transform 0.15s ease;
      }

      .side-links.blurred {
        background: var(--surface-solid);
        backdrop-filter: blur(14px);
      }

      .side-links .mono {
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .resume-hover {
        position: relative;
        display: inline-flex;
        flex-direction: column;
      }

      .resume-preview {
        position: absolute;
        top: 1.6rem;
        right: 0;
        width: 220px;
        height: 280px;
        background: var(--surface-panel);
        border: 1px solid var(--overlay);
        border-radius: 10px;
        box-shadow: 0 16px 40px var(--shadow-strong);
        opacity: 0;
        transform: translateY(6px);
        pointer-events: none;
        transition: opacity 0.2s ease, transform 0.2s ease;
        overflow: hidden;
        z-index: 3;
      }

      .resume-preview iframe {
        width: 100%;
        height: 100%;
        border: 0;
      }

      .resume-hover:hover .resume-preview,
      .resume-hover:focus-within .resume-preview {
        opacity: 1;
        transform: translateY(0);
      }

      .mobile-bar {
        display: none;
        position: fixed;
        left: 50%;
        transform: translateX(-50%);
        bottom: calc(1rem + env(safe-area-inset-bottom));
        z-index: 12;
        background: var(--surface);
        border: 1px solid rgba(var(--accent-rgb), 0.1);
        border-radius: 999px;
        padding: 0.4rem 0.8rem;
        align-items: center;
        gap: 0.6rem;
        backdrop-filter: blur(12px);
      }

      .hamburger {
        width: 36px;
        height: 32px;
        border: 1px solid var(--overlay-strong);
        background: var(--surface);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: center;
        justify-content: center;
        padding: 0;
      }

      .hamburger span {
        display: block;
        width: 18px;
        height: 2px;
        background: var(--text);
        opacity: 0.7;
      }

      .mobile-current {
        font-size: 0.85rem;
        color: var(--text-soft);
        letter-spacing: 0.02em;
        white-space: nowrap;
      }

      .mobile-current.active {
        color: var(--accent);
        text-shadow: 0 0 10px rgba(var(--accent-rgb), 0.35);
      }

      .mobile-menu {
        display: none;
        position: fixed;
        left: 1rem;
        right: 1rem;
        bottom: calc(4.2rem + env(safe-area-inset-bottom));
        background: var(--surface-panel);
        border: 1px solid var(--overlay);
        border-radius: 10px;
        padding: 0.8rem 1rem;
        backdrop-filter: blur(10px);
        z-index: 12;
      }

      .mobile-menu.open {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        text-align: center;
      }

      .mobile-menu a {
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .scroll-rail {
        position: fixed;
        left: 1.2rem;
        top: 0;
        bottom: 0;
        width: 1px;
        background: rgba(var(--accent-rgb), 0.12);
        z-index: 9;
      }

      .scroll-progress {
        position: absolute;
        left: 0;
        top: 0;
        width: 1px;
        height: 0;
        background: rgba(var(--accent-rgb), 0.5);
        transition: height 0.15s ease;
      }

      .mono {
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.85rem;
        letter-spacing: 0.01em;
        color: var(--muted);
      }
      .reading-list li {
        display: grid;
        grid-template-columns: minmax(180px, 1fr) minmax(260px, 2fr);
        gap: 1rem 1.5rem;
        align-items: baseline;
        white-space: normal;
      }

      .reading-quote {
        color: var(--muted);
        font-size: 0.85rem;
        font-style: italic;
        text-align: left;
      }

      .reading-inline {
        margin-top: 0.8rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .project-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem 1rem;
        align-items: baseline;
      }

      .experience-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .experience-subheader {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .experience-stack {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        margin-bottom: 0.4rem;
      }

      .company-name {
        color: var(--text);
        font-weight: 500;
        font-size: 0.95rem;
      }

      .exp-meta {
        opacity: 0.4;
        transition: opacity 0.2s ease;
        font-size: 0.85rem;
        font-weight: 400;
        font-family: inherit;
        line-height: 1.4;
        color: var(--muted);
      }

      .project-card:hover .exp-meta {
        opacity: 1;
      }

      .meta-block {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }


      .job-title {
        font-weight: 600;
        color: var(--text);
      }

      .project-tech {
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 400;
        line-height: 1.4;
        opacity: 0.4;
        transition: opacity 0.2s ease;
      }

      .tech-meta {
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 400;
        line-height: 1.4;
        opacity: 0.4;
        transition: opacity 0.2s ease;
      }

      .project-card:hover .tech-meta,
      .meta-card:hover .tech-meta {
        opacity: 1;
      }

      .project-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .project-impact {
        margin-top: 0.6rem;
        color: var(--text-soft);
        font-size: 0.95rem;
      }

      .project-impact strong {
        color: var(--text);
        font-weight: 600;
      }

      .project-link {
        opacity: 0;
        transition: opacity 0.2s ease, border-color 0.2s ease;
        border: 1px solid rgba(var(--accent-rgb), 0.2);
        padding: 0.3rem 0.8rem;
        border-radius: 999px;
        font-size: 0.8rem;
        color: var(--accent);
        text-decoration: none;
      }

      .project-card:hover .project-link {
        opacity: 1;
