        box-shadow: 0 0 10px rgba(var(--accent-rgb), 0.15);
      }

      .feat-gh:active {
        transform: scale(0.96);
      }

      .gh-icon {
        width: 0.85em;
        height: 0.85em;
        flex-shrink: 0;
      }

      .proj-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.85rem;
      }

      @media (hover: hover) {
        .proj-grid .proj-card {
          transition: border-color 0.25s var(--ease-out), background 0.25s var(--ease-out), transform 0.2s var(--ease-spring);
        }
