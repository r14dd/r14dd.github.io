      }

      .skill-badge {
        height: 20px;
        border-radius: 4px;
        display: inline-block;
        opacity: 0.82;
        border: 1px solid transparent;
        transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease, border-color 0.2s ease;
        vertical-align: middle;
      }

      .skill-badge:hover {
        transform: translateY(-2px);
        opacity: 1;
        border-color: rgba(var(--accent-rgb), 0.5);
      }

      html.light .skill-badge {
        filter: brightness(1.15) contrast(0.92);
        opacity: 0.88;
      }

      .skill-badge-local {
        display: inline-flex;
        align-items: center;
