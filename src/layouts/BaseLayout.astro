        if (prefersReduced) {
          document.body.classList.add("intro-done");
          document.querySelectorAll('section').forEach((s) => s.classList.add('section-revealed'));
          return;
        }
        const introPhrase = document.querySelector(".intro-phrase");
        const leads = introPhrase ? introPhrase.querySelectorAll(".lead") : [];
        const savedLang = localStorage.getItem("portfolio-lang") || "en";
        try {
          const i18nEl = document.getElementById("i18n-data");
          if (i18nEl?.textContent && introPhrase) {
            const data = JSON.parse(i18nEl.textContent);
            const langData = data?.[savedLang]?.labels;
            const hasLead = !!(langData?.introLead);
            const hasTail = !!(langData?.introTail);
            if (leads[0]) {
              if (hasLead) {
                leads[0].textContent = langData.introLead;
                leads[0].style.display = "";
              } else {
                leads[0].style.display = "none";
              }
            }
            if (leads[1]) {
              if (hasTail) {
                leads[1].textContent = langData.introTail;
                leads[1].style.display = "";
              } else {
                leads[1].style.display = "none";
              }
            } else if (hasTail) {
              const tail = document.createElement("span");
              tail.className = "lead";
              tail.textContent = langData.introTail;
              introPhrase.appendChild(tail);
            }
          }
        } catch {
          // noop
        }
        document.body.classList.add("intro-ready");
        setTimeout(() => {
          document.body.classList.add("intro-done");
          const revealObs = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('section-revealed');
                revealObs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
          document.querySelectorAll('section').forEach((s) => revealObs.observe(s));
        }, 1400);
      });

      const cursorDot = document.querySelector('.cursor-dot');
      if (cursorDot && window.matchMedia('(hover: hover)').matches) {
        let mouseX = 0, mouseY = 0, dotX = 0, dotY = 0, dotVisible = false;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          if (!dotVisible) {
            dotX = mouseX;
            dotY = mouseY;
            dotVisible = true;
            cursorDot.style.opacity = '1';
          }
        });

        document.addEventListener('mouseleave', () => {
          cursorDot.style.opacity = '0';
          dotVisible = false;
        });

        document.addEventListener('mouseover', (e) => {
          if (e.target instanceof Element && e.target.closest('a, button')) {
            cursorDot.style.transform = 'translate(-50%, -50%) scale(3)';
          } else {
            cursorDot.style.transform = 'translate(-50%, -50%) scale(1)';
          }
        });

        const animateDot = () => {
          dotX += (mouseX - dotX) * 0.15;
          dotY += (mouseY - dotY) * 0.15;
          cursorDot.style.left = dotX + 'px';
          cursorDot.style.top = dotY + 'px';
          requestAnimationFrame(animateDot);
        };
        animateDot();
      }
    </script>

