      .proj-card {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: var(--radius-md);
        padding: var(--space-4);
        transition: border-color 0.25s var(--ease-out), background 0.25s var(--ease-out), transform 0.2s var(--ease-spring);
      }

      .proj-card:hover {
        border-color: rgba(var(--accent-rgb), 0.2);
        transform: translateY(-2px);
      }

      .proj-card:active {
        transform: scale(0.985);
      }

      html.light .proj-card {
        background: transparent;
        border-color: rgba(0, 0, 0, 0.07);
      }

      html.light .proj-card:hover {
        border-color: rgba(var(--accent-rgb), 0.25);
      }

      .proj-name {
        font-size: 0.98rem;
        font-weight: 600;
        color: var(--text);
        margin: 0 0 0.5rem;
      }

      .proj-impact {
        font-size: 0.84rem;
        color: var(--text-soft);
        margin: 0 0 0.5rem;
        line-height: 1.55;
      }

      .proj-card-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
