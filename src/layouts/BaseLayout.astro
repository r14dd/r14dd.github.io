      }

      .feat-bullets li {
        position: relative;
        padding-left: 0.9rem;
        margin-bottom: 0.25rem;
        font-size: 0.86rem;
        color: var(--text-soft);
        line-height: 1.55;
      }

      .feat-bullets li::before {
        content: '\00B7';
        position: absolute;
        left: 0;
        color: rgba(var(--accent-rgb), 0.5);
        font-weight: 700;
        font-size: 1.1rem;
        line-height: 1.35;
      }

      .feat-gh {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: transparent;
        border: 1px solid rgba(var(--accent-rgb), 0.2);
        color: var(--accent);
        padding: 0.2rem 0.6rem;
        border-radius: var(--radius-full);
        font-size: 0.68rem;
        font-family: "JetBrains Mono", ui-monospace, monospace;
