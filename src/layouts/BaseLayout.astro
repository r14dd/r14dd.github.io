---
import PageLoader from '../components/PageLoader.astro';
import CursorDot from '../components/CursorDot.astro';
import ScrollLine from '../components/ScrollLine.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';

const {
  metaTitle = 'Riad Mukhtarov — Portfolio',
  metaDescription = 'Backend & Distributed Systems engineer building reliable, production‑ready, event‑driven systems.',
  metaImage = 'https://riad.cc/og-preview.jpg',
  structuredData = '',
  lang = 'en',
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

import '../styles/base.css';
import '../styles/hero.css';
import '../styles/navigation.css';
import '../styles/terminal.css';
import '../styles/experience.css';
import '../styles/projects.css';
import '../styles/simulation.css';
import '../styles/carousel.css';
import '../styles/spotify.css';
import '../styles/skills.css';
import '../styles/connect.css';
import '../styles/ui.css';
---

<!doctype html>
<html lang={lang} translate="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="google" content="notranslate" />
    <meta name="translate" content="no" />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Riad Mukhtarov — portfolio preview card" />
    <meta property="og:site_name" content="Riad Mukhtarov" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />
    <meta name="twitter:image:alt" content="Riad Mukhtarov — portfolio preview card" />
    <link rel="canonical" href={canonicalUrl} />
    {structuredData && <script type="application/ld+json" set:html={structuredData} />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta id="theme-color-meta" name="theme-color" content="#050505" />
    <script is:inline>
      const _theme = localStorage.getItem('portfolio-theme');
      if (_theme === 'light') {
        document.documentElement.classList.add('light');
        document.getElementById('theme-color-meta')?.setAttribute('content', '#ffffff');
      }
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    </script>

    <link rel="preload" href="/fonts/manrope-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/font-5.woff2" as="font" type="font/woff2" crossorigin />
    <Analytics />
  </head>

  <body>
    <noscript
      ><style>
        .page-loader,
        .cursor-dot,
        .scroll-line,
        .terminal-cursor,
        .spotify-line,
        .cmd-palette {
          display: none !important;
        }
        .terminal-body {
          min-height: auto !important;
        }
      </style></noscript
    >
    <a href="#main-content" class="skip-link">Skip to content</a>
    <PageLoader />
    <CursorDot />
    <ScrollLine />
    <slot />

    <script>
      // Buttery wheel scrolling: Lenis eases wheel input toward its target on
      // an rAF loop. Loaded as a pointer-gated dynamic import so touch-only
      // devices (which keep native scrolling anyway) never download the chunk;
      // reduced-motion users keep instant scrolling. Scroll events still fire
      // natively so every existing scroll listener works unchanged. Exposed as
      // window.__lenis so anchor navigation routes through it — any external
      // per-frame scrollTo animation would fight the lerp.
      if (
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
        window.matchMedia('(pointer: fine)').matches
      ) {
        import('lenis').then(({ default: Lenis }) => {
          const lenis = new Lenis({ duration: 1.1, smoothWheel: true, syncTouch: false });
          (window as any).__lenis = lenis;
          const raf = (time: number) => {
            lenis.raf(time);
            requestAnimationFrame(raf);
          };
          requestAnimationFrame(raf);
        });
      }

      document.addEventListener('click', (e) => {
        const target = e.target as Element;
        if (target.closest('.section-block h2')) {
          const hint = document.querySelector('.section-hint');
          if (hint) hint.remove();
        }
      });

      window.addEventListener('pageshow', (e) => {
        if (e.persisted) {
          window.scrollTo(0, 0);
        }
      });

      window.addEventListener('load', () => {
        window.scrollTo(0, 0);
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        document.body.classList.add('intro-done');
        if (prefersReduced) {
          document.querySelectorAll('section').forEach((s) => {
            s.classList.add('section-revealed');
          });
          return;
        }
        document.querySelectorAll('section:not([id])').forEach((s) => {
          s.classList.add('section-revealed');
        });
        const revealIO = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('section-revealed');
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0, rootMargin: '0px 0px -15% 0px' },
        );
        document.querySelectorAll('section[id]').forEach((s) => revealIO.observe(s));
      });
    </script>

    <Footer />
  </body>
</html>
