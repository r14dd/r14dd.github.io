      /* ── PROJECTS ─────────────────────────────────────── */

      .proj-section {
        padding-top: 2.5rem;
      }

      .feat-card {
        position: relative;
        background: transparent;
        border: 1px solid rgba(var(--accent-rgb), 0.14);
        border-radius: var(--radius-md);
        padding: var(--space-6);
