      }

      .tech-meta {
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 400;
        line-height: 1.4;
        opacity: 0.4;
        transition: opacity 0.2s ease;
      }

      .project-card:hover .tech-meta,
      .meta-card:hover .tech-meta {
        opacity: 1;
      }

      .project-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .project-impact {
        margin-top: 0.6rem;
        color: var(--text-soft);
        font-size: 0.95rem;
      }

      .project-impact strong {
        color: var(--text);
        font-weight: 600;
      }

      .project-link {
        opacity: 0;
        transition: opacity 0.2s ease, border-color 0.2s ease;
        border: 1px solid rgba(var(--accent-rgb), 0.2);
        padding: 0.3rem 0.8rem;
        border-radius: 999px;
        font-size: 0.85rem;
        color: var(--accent);
