      .play-icon {
        width: 0.85em;
        height: 0.85em;
        flex-shrink: 0;
      }

      .sim-toggle:hover {
        border-color: rgba(var(--accent-rgb), 0.45);
        box-shadow: 0 0 10px rgba(var(--accent-rgb), 0.15);
      }

      .sim-toggle:active {
        transform: scale(0.96);
      }

      .proj-card .sim-visual {
        display: none;
      }

      .sim-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0);
        backdrop-filter: blur(0);
        -webkit-backdrop-filter: blur(0);
        pointer-events: none;
        transition: background 0.22s var(--ease-in), backdrop-filter 0.22s var(--ease-in), -webkit-backdrop-filter 0.22s var(--ease-in);
      }

      .sim-overlay.open {
        background: rgba(0, 0, 0, 0.65);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        pointer-events: auto;
