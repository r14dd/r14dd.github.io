  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
        <div class="page-loader" aria-hidden="true">
      <svg class="loader-mark" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
        <rect width="512" height="512" rx="96" fill="currentColor" opacity="0.08"/>
        <text x="256" y="365" text-anchor="middle" font-family="'Georgia','Times New Roman',serif" font-weight="700" font-size="340" fill="currentColor" letter-spacing="-8">R</text>
      </svg>
    </div>
    <div class="cursor-dot" aria-hidden="true"></div>
    <div class="scroll-line" aria-hidden="true"><div class="scroll-line-fill"></div></div>
    <slot />
    <script>

      const scrollFill = document.querySelector('.scroll-line-fill');
      if (scrollFill) {
        const scrollLine = document.querySelector('.scroll-line');
        let current = 0, target = 0;
        const lerp = (a, b, t) => a + (b - a) * t;
        const updateScroll = () => {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          target = max > 0 ? (window.scrollY / max) * 100 : 0;
          current = lerp(current, target, 0.1);
          scrollFill.style.height = current.toFixed(2) + '%';
          if (scrollLine) scrollLine.style.opacity = current < 1 ? '0' : '1';
          requestAnimationFrame(updateScroll);
        };
        requestAnimationFrame(updateScroll);
      }

      document.addEventListener('click', (e) => {
        if (e.target.closest('.section-block h2')) {
          const hint = document.querySelector('.section-hint');
          if (hint) hint.remove();
        }
      });

      window.addEventListener("pageshow", (e) => {
        if (e.persisted) {
          window.scrollTo(0, 0);
        }
      });

      window.addEventListener("load", () => {
        window.scrollTo(0, 0);
        const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        document.body.classList.add("intro-done");
        if (prefersReduced) {
          document.querySelectorAll('section').forEach((s) => {
            s.classList.add('section-revealed');
          });
          return;
        }
        const isTouch = window.matchMedia('(hover: none)').matches;
        const revealObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('section-revealed');
              revealObs.unobserve(entry.target);
            }
          });
        }, {
          threshold: isTouch ? 0.02 : 0.08,
          rootMargin: isTouch ? '0px 0px 20px 0px' : '0px 0px -40px 0px'
        });
        document.querySelectorAll('section').forEach((s) => revealObs.observe(s));
      });


      // Text generate — split hero about into words and reveal
      const heroAboutEl = document.getElementById('hero-about');
      if (heroAboutEl && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const text = heroAboutEl.textContent.trim();
        heroAboutEl.innerHTML = text.split(' ').map(w => `<span class="word-gen">${w}</span>`).join(' ');
        const words = heroAboutEl.querySelectorAll('.word-gen');
        words.forEach((w, i) => {
          setTimeout(() => w.classList.add('revealed'), 100 + i * 40);
        });
      }

      const cursorDot = document.querySelector('.cursor-dot');
      const cursorReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (cursorDot && window.matchMedia('(hover: hover)').matches && !cursorReduced) {
        document.body.classList.add('cursor-active');
        let mouseX = 0, mouseY = 0, dotX = 0, dotY = 0, dotVisible = false;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          if (!dotVisible) {
            dotX = mouseX;
            dotY = mouseY;
            dotVisible = true;
            cursorDot.style.opacity = '1';
          }
        });

        document.addEventListener('mouseleave', () => {
          cursorDot.style.opacity = '0';
          dotVisible = false;
        });

        document.addEventListener('mouseover', (e) => {
          if (e.target instanceof Element && e.target.closest('a, button')) {
            cursorDot.style.transform = 'translate(-50%, -50%) scale(3)';
          } else {
            cursorDot.style.transform = 'translate(-50%, -50%) scale(1)';
          }
        });

        const TRAIL_COUNT = 8;
        const trailEls = [];
        for (let i = 0; i < TRAIL_COUNT; i++) {
          const t = document.createElement('div');
          t.className = 'cursor-trail';
          document.body.appendChild(t);
          trailEls.push({ el: t, x: 0, y: 0 });
        }

        const animateDot = () => {
          dotX += (mouseX - dotX) * 0.15;
          dotY += (mouseY - dotY) * 0.15;
          cursorDot.style.left = dotX + 'px';
          cursorDot.style.top = dotY + 'px';
          for (let i = trailEls.length - 1; i > 0; i--) {
            trailEls[i].x = trailEls[i - 1].x;
            trailEls[i].y = trailEls[i - 1].y;
          }
          trailEls[0].x = dotX;
          trailEls[0].y = dotY;
          trailEls.forEach((t, i) => {
            t.el.style.left = t.x + 'px';
            t.el.style.top = t.y + 'px';
            t.el.style.opacity = dotVisible ? (1 - i / TRAIL_COUNT) * 0.35 : 0;
            t.el.style.transform = `translate(-50%,-50%) scale(${1 - i * 0.08})`;
          });
          requestAnimationFrame(animateDot);
        };
        animateDot();
      }

    </script>

