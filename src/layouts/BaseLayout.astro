      .section-revealed ul li {
        opacity: 0;
        animation: li-stagger 0.35s ease forwards;
      }

      .section-revealed ul li:nth-child(1) { animation-delay: 0.10s; }
      .section-revealed ul li:nth-child(2) { animation-delay: 0.18s; }
      .section-revealed ul li:nth-child(3) { animation-delay: 0.26s; }
      .section-revealed ul li:nth-child(4) { animation-delay: 0.34s; }
      .section-revealed ul li:nth-child(5) { animation-delay: 0.42s; }
      .section-revealed ul li:nth-child(6) { animation-delay: 0.50s; }
      .section-revealed ul li:nth-child(7) { animation-delay: 0.58s; }
      .section-revealed ul li:nth-child(8) { animation-delay: 0.66s; }

      @keyframes li-stagger {
        from { opacity: 0; transform: translateX(-6px); }
        to { opacity: 1; transform: translateX(0); }
      }


      .skills-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-top: 0.45rem;
