---
const {
  metaTitle = "Riad Mukhtarov — Portfolio",
  metaDescription = "Backend & Distributed Systems engineer building reliable, production‑ready, event‑driven systems.",
  metaImage = "https://riad.cc/og-preview.jpg",
  structuredData = "",
  lang = "en",
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang} translate="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="google" content="notranslate" />
    <meta name="translate" content="no" />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://riad.cc" />
    <meta property="og:image" content={metaImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />
    <link rel="canonical" href="https://riad.cc" />
    <link rel="alternate" hreflang="en" href="https://riad.cc" />
    <link rel="alternate" hreflang="ru" href="https://riad.cc" />
    <link rel="alternate" hreflang="az" href="https://riad.cc" />
    <link rel="alternate" hreflang="x-default" href="https://riad.cc" />
    {structuredData && <script type="application/ld+json" set:html={structuredData} />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta id="theme-color-meta" name="theme-color" content="#050505" />
    <script is:inline>
      // Dark is the default theme; switch to light only when explicitly chosen.
      const _theme = localStorage.getItem('portfolio-theme');
      if (_theme === 'light') {
        document.documentElement.classList.add('light');
        document.getElementById('theme-color-meta')?.setAttribute('content', '#faf9f6');
      }
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    </script>

    <link rel="preload" href="/fonts/font-8.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/font-5.woff2" as="font" type="font/woff2" crossorigin />

    <style is:global>
      @font-face { font-family: 'Cormorant Garamond'; font-style: italic; font-weight: 400; font-display: swap; src: url(/fonts/font-0.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
      @font-face { font-family: 'Cormorant Garamond'; font-style: italic; font-weight: 400; font-display: swap; src: url(/fonts/font-1.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
      @font-face { font-family: 'Cormorant Garamond'; font-style: italic; font-weight: 400; font-display: swap; src: url(/fonts/font-2.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
      @font-face { font-family: 'Cormorant Garamond'; font-style: normal; font-weight: 600; font-display: swap; src: url(/fonts/font-3.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
      @font-face { font-family: 'Cormorant Garamond'; font-style: normal; font-weight: 600; font-display: swap; src: url(/fonts/font-4.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
      @font-face { font-family: 'Cormorant Garamond'; font-style: normal; font-weight: 600; font-display: swap; src: url(/fonts/font-5.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 100 900; font-display: swap; src: url(/fonts/font-6.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 100 900; font-display: swap; src: url(/fonts/font-7.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 100 900; font-display: swap; src: url(/fonts/font-8.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
      @font-face { font-family: 'JetBrains Mono'; font-style: normal; font-weight: 400; font-display: swap; src: url(/fonts/font-9.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
      @font-face { font-family: 'JetBrains Mono'; font-style: normal; font-weight: 400; font-display: swap; src: url(/fonts/font-10.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
      @font-face { font-family: 'JetBrains Mono'; font-style: normal; font-weight: 400; font-display: swap; src: url(/fonts/font-11.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
      @font-face { font-family: 'JetBrains Mono'; font-style: normal; font-weight: 500; font-display: swap; src: url(/fonts/font-9.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
      @font-face { font-family: 'JetBrains Mono'; font-style: normal; font-weight: 500; font-display: swap; src: url(/fonts/font-10.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
      @font-face { font-family: 'JetBrains Mono'; font-style: normal; font-weight: 500; font-display: swap; src: url(/fonts/font-11.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }

      :root {
        --bg: #050505;
        --bg-rgb: 5, 5, 5;
        --text: #eeeeee;
        --text-soft: #a1a1a1;
        --muted: #888888;
        --accent: #c9a55a;
        --accent-rgb: 201, 165, 90;
        --border: rgba(255, 255, 255, 0.06);
        --surface: rgba(5, 5, 5, 0.6);
        --surface-solid: rgba(5, 5, 5, 0.75);
        --surface-panel: rgba(12, 12, 12, 0.9);
        --overlay: rgba(255, 255, 255, 0.06);
        --overlay-strong: rgba(255, 255, 255, 0.1);
        --shadow: rgba(0, 0, 0, 0.4);
        --shadow-strong: rgba(0, 0, 0, 0.55);
        --noise-opacity: 0.035;
        --card-hover: rgba(var(--accent-rgb), 0.025);
        --selection: rgba(var(--accent-rgb), 0.2);
        --marker: rgba(var(--accent-rgb), 0.45);
        --ease-spring: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-out: cubic-bezier(0.33, 1, 0.68, 1);
        --ease-in: cubic-bezier(0.55, 0, 1, 0.68);

        --text-xs: 0.72rem;
        --text-sm: 0.82rem;
        --text-base: 1rem;
        --text-md: 1.2rem;
        --text-lg: 1.15rem;
        --text-xl: 1.55rem;

        --space-1: 0.25rem;
        --space-2: 0.5rem;
        --space-3: 0.75rem;
        --space-4: 1rem;
        --space-6: 1.5rem;
        --space-8: 2rem;
        --space-12: 3rem;
        --space-16: 4rem;
        --space-20: 5rem;

        --radius-sm: 4px;
        --radius-md: 10px;
        --radius-lg: 14px;
        --radius-full: 999px;

        --accent-hover: rgba(var(--accent-rgb), 0.45);
        --accent-muted: rgba(var(--accent-rgb), 0.25);
        --accent-subtle: rgba(var(--accent-rgb), 0.12);

        color-scheme: dark;
      }

      html.light {
        --bg: #faf9f6;
        --bg-rgb: 250, 249, 246;
        --text: #1c1917;
        --text-soft: #3b3835;
        --muted: #6b6560;
        --accent: var(--accent-light, #a8863d);
        --accent-rgb: var(--accent-light-rgb, 168, 134, 61);
        --border: rgba(0, 0, 0, 0.06);
        --surface: rgba(255, 255, 255, 0.7);
        --surface-solid: rgba(255, 255, 255, 0.85);
        --surface-panel: rgba(255, 255, 255, 0.95);
        --overlay: rgba(0, 0, 0, 0.04);
        --overlay-strong: rgba(0, 0, 0, 0.08);
        --shadow: rgba(0, 0, 0, 0.1);
        --shadow-strong: rgba(0, 0, 0, 0.15);
        --noise-opacity: 0.02;
        --card-hover: rgba(var(--accent-rgb), 0.06);
        --selection: rgba(var(--accent-rgb), 0.25);
        --marker: rgba(var(--accent-rgb), 0.6);
        color-scheme: light;
      }

      * {
        box-sizing: border-box;
      }

      input, textarea {
        user-select: text;
        -webkit-user-select: text;
      }

      :focus-visible {
        outline: 2px solid rgba(var(--accent-rgb), 0.6);
        outline-offset: 3px;
        border-radius: 4px;
      }

      /* Keyboard skip link — hidden off-screen until focused (WCAG 2.4.1). */
      .skip-link {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1000;
        margin: 0.6rem;
        padding: 0.6rem 1rem;
        background: var(--surface-panel);
        color: var(--accent);
        border: 1px solid var(--accent-muted);
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        font-weight: 500;
        text-decoration: none;
        transform: translateY(-150%);
        transition: transform 0.18s var(--ease-out);
      }
      .skip-link:focus {
        transform: translateY(0);
      }


      html {
        background: var(--bg);
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }

      @media (prefers-reduced-motion: no-preference) {
        html { scroll-behavior: smooth; }
      }

      body {
        background-color: var(--bg);
        color: var(--text-soft);
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 0;
        padding: 3rem 1.5rem 4rem;
        padding-top: max(3rem, env(safe-area-inset-top));
        padding-left: max(1.5rem, env(safe-area-inset-left));
        padding-right: max(1.5rem, env(safe-area-inset-right));
        line-height: 1.65;
        font-size: 16px;
        -webkit-tap-highlight-color: transparent;
        overscroll-behavior-y: none;
      }

      .content {
        max-width: 840px;
        margin: 0 auto;
      }

      .content,
      .side-nav,
      .side-links,
      .lang-switcher {
        transition: opacity 0.2s ease;
      }

      body.lang-switching .content,
      body.lang-switching .side-nav,
      body.lang-switching .side-links,
      body.lang-switching .lang-switcher {
        opacity: 0;
        pointer-events: none;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: var(--text-xs);
        font-family: "JetBrains Mono", ui-monospace, monospace;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(var(--accent-rgb), 0.65);
        margin: 0 0 0.6rem;
      }

      .eyebrow-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(var(--accent-rgb), 0.65);
        flex-shrink: 0;
      }

      h1 {
        font-size: clamp(2.8rem, 8vw, 4.8rem);
        margin: 0 0 0.4rem;
        font-family: "Cormorant Garamond", Georgia, serif;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .hero-word-wrap {
        display: inline-block;
        overflow: hidden;
        vertical-align: bottom;
      }

      .hero-word {
        display: inline-block;
        transform: translateY(110%);
        background: linear-gradient(
          100deg,
          var(--text) 0%,
          rgba(var(--accent-rgb), .95) 40%,
          var(--text) 70%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: word-rise 0.6s var(--ease-spring) forwards,
                   shimmer 6s linear 0.8s 2;
      }

      @keyframes word-rise {
        to { transform: translateY(0); }
      }

      @keyframes shimmer {
        to { background-position: -200% center; }
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-word { animation: none; transform: none; }
      }


      h2 {
        font-size: var(--text-xl);
        margin: 0 0 1rem 0;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--text);
      }

      h3 {
        font-size: 1rem;
        margin: 0.7rem 0 0.4rem 0;
        font-weight: 500;
        color: var(--text);
      }

      section {
        padding: 0;
        margin: var(--space-16) 0 0;
      }

      section:first-of-type {
        margin-top: 2.5rem;
      }

      .lang-switcher {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 200;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .theme-toggle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: 1px solid var(--accent-subtle);
        background: var(--surface);
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        color: var(--accent);
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition: box-shadow 0.25s var(--ease-out), border-color 0.25s var(--ease-out), transform 0.15s var(--ease-spring);
      }

      .theme-toggle:hover {
        border-color: rgba(var(--accent-rgb), 0.3);
        box-shadow: 0 0 18px rgba(var(--accent-rgb), 0.15);
      }

      .theme-toggle:active {
        transform: scale(0.92);
      }

      .sound-toggle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: 1px solid var(--accent-subtle);
        background: var(--surface);
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        color: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition: box-shadow 0.25s var(--ease-out), border-color 0.25s var(--ease-out), transform 0.15s var(--ease-spring);
      }
      .sound-toggle:hover {
        border-color: rgba(var(--accent-rgb), 0.3);
        box-shadow: 0 0 18px rgba(var(--accent-rgb), 0.15);
      }
      .sound-toggle:active {
        transform: scale(0.92);
      }
      .sound-toggle svg {
        width: 16px;
        height: 16px;
      }
      .sound-muted .sound-wave-1,
      .sound-muted .sound-wave-2 {
        display: none;
      }
      .sound-muted .sound-toggle svg polygon {
        opacity: 0.4;
      }

      .lang-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.55rem 0.9rem;
        border-radius: var(--radius-full);
        border: 1px solid var(--accent-subtle);
        background: var(--surface);
        color: var(--accent);
        font-size: 0.9rem;
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        transition: box-shadow 0.25s var(--ease-out), border-color 0.25s var(--ease-out), transform 0.2s var(--ease-spring);
      }

      .lang-toggle:hover {
        border-color: rgba(var(--accent-rgb), 0.3);
        box-shadow: 0 0 18px rgba(var(--accent-rgb), 0.15);
      }

      .lang-toggle:active {
        transform: scale(0.95);
      }

      .lang-globe {
        width: 15px;
        height: 15px;
        display: flex;
        align-items: center;
        color: var(--accent);
        flex-shrink: 0;
      }
      .lang-globe svg {
        width: 100%;
        height: 100%;
      }

      .lang-caret {
        opacity: 0.7;
      }

      .lang-menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 0;
        display: flex;
        flex-direction: column;
        min-width: min(180px, calc(100vw - 2rem));
        padding: 0.5rem;
        border-radius: var(--radius-lg);
        background: var(--surface-panel);
        border: 1px solid var(--overlay);
        -webkit-backdrop-filter: blur(12px);
        backdrop-filter: blur(12px);
        box-shadow: 0 16px 40px var(--shadow);
        opacity: 0;
        transform: scale(0.92) translateY(-6px);
        transform-origin: top right;
        pointer-events: none;
        transition: opacity 0.15s var(--ease-out), transform 0.15s var(--ease-out);
      }

      .lang-menu.open {
        opacity: 1;
        transform: scale(1) translateY(0);
        pointer-events: auto;
        transition: opacity 0.2s var(--ease-out), transform 0.22s var(--ease-spring);
      }

      .lang-menu button {
        background: transparent;
        border: none;
        color: var(--text-soft);
        text-align: left;
        padding: 0.5rem 0.65rem;
        border-radius: var(--radius-md);
        font-size: 0.95rem;
        transition: background 0.2s var(--ease-out), color 0.2s var(--ease-out);
      }

      .lang-menu button:hover {
        background: var(--overlay);
        color: var(--text);
      }


      p {
        margin-top: 0.6rem;
        color: var(--text-soft);
      }

      small {
        display: block;
        margin-bottom: 0.6rem;
        color: var(--muted);
      }

      ul {
        padding-left: 1.2rem;
        margin-top: 0.6rem;
      }

      li {
        margin-bottom: 0.4rem;
        color: var(--text-soft);
      }

      li::marker {
        color: var(--marker);
      }

      code {
        background: var(--overlay);
        border: 1px solid var(--overlay-strong);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        color: var(--text);
        font-size: 0.88em;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      }

      strong {
        color: var(--text);
      }

      em {
        color: var(--muted);
        font-style: italic;
      }

      a {
        color: var(--text);
        text-decoration: none;
        background-image: linear-gradient(rgba(var(--accent-rgb), 0.5), rgba(var(--accent-rgb), 0.5));
        background-size: 0% 1px;
        background-position: left bottom;
        background-repeat: no-repeat;
        transition: background-size 0.3s var(--ease-out), opacity 0.2s var(--ease-out);
      }

      a:hover {
        background-size: 100% 1px;
        opacity: 0.85;
      }

      ::selection {
        background: var(--selection);
        color: var(--text);
      }

      a, button, input, select, textarea, [role="button"], summary {
        touch-action: manipulation;
      }

      .page-loader {
        position: fixed;
        inset: 0;
        background: var(--bg);
        z-index: 999;
        display: grid;
        place-items: center;
        pointer-events: none;
        animation: loader-exit 0.4s var(--ease-out) 0.5s forwards;
      }

      .loader-mark {
        width: 48px;
        height: 48px;
        color: var(--accent);
        opacity: 0;
        transform: scale(0.85);
        animation: loader-in 0.4s var(--ease-spring) 0.05s forwards;
      }

      @keyframes loader-in {
        to { opacity: 1; transform: scale(1); }
      }

      @keyframes loader-exit {
        to { opacity: 0; visibility: hidden; }
      }

      section {
        opacity: 0;
        transform: translateX(-18px);
        transition: transform 0.5s var(--ease-spring), opacity 0.5s var(--ease-spring);
      }

      section:nth-of-type(even) {
        transform: translateX(18px);
      }

      section.section-revealed {
        opacity: 1;
        transform: translateX(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .page-loader {
          display: none !important;
        }

        section {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }

        .project-card,
        .meta-card {
          transform: none !important;
          transition: none !important;
        }

        .project-card::before,
        .meta-card::before {
          display: none !important;
        }

        .section-revealed .project-card,
        .section-revealed .meta-card,
        .section-revealed .tl-item,
        #connect.section-revealed .connect-links .cta-btn {
          opacity: 1 !important;
          transform: none !important;
          animation: none !important;
        }

        .section-revealed ul li {
          opacity: 1 !important;
          transform: none !important;
          animation: none !important;
        }

        .cursor-dot { display: none !important; }
      }

      footer {
        margin-top: 4rem;
        padding-top: 2rem;
        text-align: center;
        font-size: 0.75rem;
        color: var(--muted);
        border-top: 1px solid rgba(var(--accent-rgb), 0.1);
      }

      .section-block {
        padding-top: var(--space-4);
        margin-top: var(--space-12);
      }

      .side-nav {
        position: fixed;
        left: clamp(.8rem, 2.5vw, 2.8rem);
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: .45rem;
        z-index: 100;
      }

      .side-nav a {
        font-family: 'JetBrains Mono', monospace;
        font-size: .68rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        padding: .2rem 0;
        display: flex;
        align-items: center;
        gap: .5rem;
        border-bottom: none;
        background-image: none;
        transition: color .2s;
      }

      .side-nav a::before {
        content: '';
        width: 0;
        height: 1px;
        background: var(--accent);
        transition: width .25s ease;
        flex-shrink: 0;
      }

      .side-nav a.active {
        color: var(--accent);
      }

      .side-nav a.active::before {
        width: 1rem;
      }

      .side-links {
        position: fixed;
        right: 2.5rem;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        padding: 0.8rem 1rem;
        background: var(--surface);
        border: 1px solid rgba(var(--accent-rgb), 0.08);
        border-radius: 12px;
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        z-index: 10;
      }

      .side-links a {
        border-bottom: none;
        background-image: none;
        font-family: 'JetBrains Mono', monospace;
        font-size: .68rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        transition: color .2s;
      }

      .side-links.blurred {
        background: var(--surface-solid);
        -webkit-backdrop-filter: blur(14px);
        backdrop-filter: blur(14px);
      }

      .side-links .mono {
        font-family: 'JetBrains Mono', monospace;
        font-size: .68rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .pull-indicator {
        position: fixed;
        top: -3rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        border: 1.5px solid rgba(var(--accent-rgb), 0.2);
        background: var(--surface);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: top 0.2s ease, opacity 0.2s ease;
        pointer-events: none;
      }
      .pull-indicator svg { width: 16px; height: 16px; color: var(--accent); }
      .pull-indicator.visible {
        top: 1rem;
        opacity: 1;
      }
      .pull-indicator.refreshing svg {
        animation: pull-spin 0.6s linear infinite;
      }
      @keyframes pull-spin {
        to { transform: rotate(360deg); }
      }


      .sim-visual {
        touch-action: manipulation;
      }
      .sim-visual.pinch-zooming {
        transform-origin: var(--pinch-x, 50%) var(--pinch-y, 50%);
        transition: none;
      }

      .easter-overlay {
        position: fixed;
        inset: 0;
        z-index: 20000;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.4s ease;
        overflow: hidden;
      }
      .easter-overlay.active {
        opacity: 1;
      }
      .matrix-col {
        position: absolute;
        top: -100%;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        line-height: 1.1;
        color: var(--accent);
        writing-mode: vertical-rl;
        text-orientation: upright;
        animation: matrix-fall linear forwards;
        opacity: 0.7;
        text-shadow: 0 0 8px rgba(var(--accent-rgb), 0.5);
        white-space: nowrap;
      }
      @keyframes matrix-fall {
        0% { top: -100%; opacity: 0.7; }
        90% { opacity: 0.7; }
        100% { top: 100vh; opacity: 0; }
      }



      .mono {
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.85rem;
        letter-spacing: 0.01em;
        color: var(--muted);
      }
      .project-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem 1rem;
        align-items: baseline;
      }

      .experience-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .experience-subheader {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .experience-stack {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        margin-bottom: 0.4rem;
      }

      .company-name {
        color: var(--text);
        font-weight: 500;
        font-size: 0.95rem;
      }

      .exp-meta {
        opacity: 0.4;
        transition: opacity 0.2s ease;
        font-size: 0.85rem;
        font-weight: 400;
        font-family: inherit;
        line-height: 1.4;
        color: var(--muted);
      }

      .project-card:hover .exp-meta {
        opacity: 1;
      }

      .exp-section {
        padding-top: 2.5rem;
      }

      .sec-eyebrow {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.68rem;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(var(--accent-rgb), 0.55);
        margin-bottom: 0.4rem;
      }

      .sec-eyebrow::after {
        content: '';
