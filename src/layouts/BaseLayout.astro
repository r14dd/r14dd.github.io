      @keyframes cta-pulse {
        0%, 100% { box-shadow: 0 0 0 rgba(var(--accent-rgb), 0); }
        50% { box-shadow: 0 0 18px rgba(var(--accent-rgb), 0.28), 0 0 36px rgba(var(--accent-rgb), 0.1); }
