      }

      .tl-item ul {
        list-style: none;
        padding-left: 0;
        margin: 0;
      }

      .tl-item ul li {
        position: relative;
        padding-left: 1rem;
        margin-bottom: 0.25rem;
        font-size: 0.86rem;
        color: var(--text-soft);
        line-height: 1.55;
      }

      .tl-item ul li::before {
        content: '\2014';
        position: absolute;
        left: 0;
        top: 0.1rem;
        color: rgba(var(--accent-rgb), 0.3);
        font-size: 0.7rem;
      }

      .tl-item ul li::marker {
        content: none;
