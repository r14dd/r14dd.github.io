          display: none;
        }
      }

      .simulate-btn {
        background: transparent;
        border: 1px solid rgba(var(--accent-rgb), 0.2);
        color: var(--accent);
        padding: 0.3rem 0.8rem;
        border-radius: 999px;
        font-size: 0.85rem;
        transition: opacity 0.2s ease, border-color 0.2s ease, color 0.2s ease;
        opacity: 0;
      }

      .project-card:hover .simulate-btn {
        opacity: 1;
        box-shadow: 0 0 12px rgba(var(--accent-rgb), 0.12);
      }

      .project-card:hover .simulate-btn:hover {
        border-color: rgba(var(--accent-rgb), 0.5);
        color: var(--accent);
        box-shadow: 0 0 14px rgba(var(--accent-rgb), 0.22);
      }

      .sim-visual {
        margin-top: 0.8rem;
        opacity: 0;
        max-height: 0;
        overflow: hidden;
        transition: opacity 0.3s ease, max-height 0.3s ease;
      }

      .sim-visual.active {
        opacity: 1;
        max-height: 200px;
      }

      .sim-visual svg {
        width: 320px;
        max-width: 100%;
        height: auto;
        display: block;
      }

      .sim-node {
        fill: rgba(var(--accent-rgb), 0.1);
        stroke: rgba(var(--accent-rgb), 0.25);
        stroke-width: 1;
      }

      .sim-leader-node {
        fill: rgba(var(--accent-rgb), 0.22);
        stroke: rgba(var(--accent-rgb), 0.55);
        stroke-width: 1.5;
      }

      .sim-target-node {
        fill: rgba(var(--accent-rgb), 0.25);
        stroke: rgba(var(--accent-rgb), 0.6);
        stroke-width: 1.5;
      }

      .sim-link {
        stroke: rgba(var(--accent-rgb), 0.2);
        stroke-width: 1;
      }

      .sim-heartbeat {
        stroke: rgba(var(--accent-rgb), 0.15);
        stroke-width: 1;
        stroke-dasharray: 6 4;
      }

      .sim-label {
        fill: rgba(var(--accent-rgb), 0.6);
        font-size: 9px;
        text-anchor: middle;
        dominant-baseline: middle;
      }

      .sim-desc {
        fill: rgba(var(--accent-rgb), 0.35);
        font-size: 7px;
        text-anchor: middle;
        letter-spacing: 0.08em;
      }

      .sim-legend {
        margin-top: 0.4rem;
        font-size: 0.75rem;
        color: rgba(var(--accent-rgb), 0.45);
        letter-spacing: 0.01em;
      }

      .sim-pulse {
        fill: rgba(var(--accent-rgb), 0.75);
      }

      .sim-log {
        fill: rgba(var(--accent-rgb), 0.08);
        stroke: rgba(var(--accent-rgb), 0.18);
        stroke-width: 0.5;
      }

      .sim-log-new {
        fill: rgba(var(--accent-rgb), 0.25);
        stroke: rgba(var(--accent-rgb), 0.4);
        stroke-width: 0.5;
      }

      .sim-layer-bg {
        fill: rgba(var(--accent-rgb), 0.03);
        stroke: rgba(var(--accent-rgb), 0.12);
        stroke-width: 1;
      }

      .sim-layer-title {
        fill: rgba(var(--accent-rgb), 0.4);
        font-size: 7.5px;
        text-anchor: middle;
        letter-spacing: 0.1em;
      }

      .sim-entry {
        fill: rgba(var(--accent-rgb), 0.06);
        stroke: rgba(var(--accent-rgb), 0.15);
        stroke-width: 0.5;
      }

      .sim-entry-text {
        fill: rgba(var(--accent-rgb), 0.45);
        font-size: 7px;
        text-anchor: middle;
        dominant-baseline: middle;
      }

      .sim-ttl-track {
        fill: rgba(var(--accent-rgb), 0.06);
      }

      .sim-ttl-fill {
        fill: rgba(var(--accent-rgb), 0.4);
      }

      .sim-arrow {
        fill: rgba(var(--accent-rgb), 0.35);
      }

      .sim-ghost {
        opacity: 0.25;
      }

      .sim-visual.active .sim-heartbeat {
        stroke: rgba(var(--accent-rgb), 0.3);
        animation: dash 1.4s linear infinite;
      }

      .sim-visual.active .sim-link {
        stroke-dasharray: 3 4;
        animation: dash 1.2s linear infinite;
      }

      .sim-visual.active .sim-node {
        animation: nodeGlow 1.6s ease forwards;
      }

      .sim-visual.active .sim-leader-node {
        animation: leaderGlow 2s ease-in-out infinite;
      }

      .sim-visual.active .sim-target-node {
        animation: leaderGlow 2s ease-in-out infinite;
      }

      @keyframes dash {
        to { stroke-dashoffset: -14; }
      }

      @keyframes nodeGlow {
        0% { fill: rgba(var(--accent-rgb), 0.1); stroke: rgba(var(--accent-rgb), 0.25); }
        40% { fill: rgba(var(--accent-rgb), 0.3); stroke: rgba(var(--accent-rgb), 0.5); }
        100% { fill: rgba(var(--accent-rgb), 0.15); stroke: rgba(var(--accent-rgb), 0.3); }
      }

      @keyframes leaderGlow {
        0%, 100% { fill: rgba(var(--accent-rgb), 0.22); stroke: rgba(var(--accent-rgb), 0.55); }
        50% { fill: rgba(var(--accent-rgb), 0.38); stroke: rgba(var(--accent-rgb), 0.7); }
      }

      .content ul li {
        white-space: normal;
      }

      .testi-wrap { position: relative; overflow: hidden; }
      .testi-scroll {
        display: flex;
        gap: 1rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding-bottom: 0.25rem;
      }
      .testi-scroll::-webkit-scrollbar { display: none; }
      .testi-card {
        flex: 0 0 100%;
        min-height: 260px;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        scroll-snap-align: start;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.8rem 2rem;
      }
      .testi-mark {
        font-size: 5rem;
        line-height: .4;
        color: rgba(var(--accent-rgb), .18);
        display: block;
        margin-bottom: 1rem;
      }
      .testi-quote {
        font-size: 1.05rem;
        font-style: italic;
        color: var(--text-soft);
        line-height: 1.7;
        margin: 0 0 1.5rem;
        flex: 1;
      }
      .testi-author {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-top: auto;
      }
      .testi-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        flex-shrink: 0;
        background: rgba(var(--accent-rgb), .1);
        border: 1px solid rgba(var(--accent-rgb), .2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'JetBrains Mono', monospace;
        font-size: .72rem;
        color: var(--accent);
      }
      .testi-name {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-weight: 600;
        color: var(--text);
        font-size: .88rem;
      }
      .testi-linkedin {
        display: inline-flex;
        align-items: center;
        color: var(--muted);
        opacity: 0.5;
        transition: opacity 0.2s ease, color 0.2s ease;
        background-image: none;
      }
      .testi-linkedin:hover {
        opacity: 1;
        color: var(--accent);
        background-size: 0% 1px;
      }
      .testi-linkedin svg {
        width: 13px;
        height: 13px;
      }
      .testi-role {
        font-size: .76rem;
        color: var(--muted);
      }
      .testi-course {
        font-family: 'JetBrains Mono', monospace;
        font-size: .68rem;
        color: rgba(var(--accent-rgb), .55);
        margin-top: .1rem;
      }
      .carousel-nav {
        display: flex;
        align-items: center;
        gap: .9rem;
        margin-top: 1.1rem;
      }
      .car-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-soft);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: border-color .2s, color .2s;
      }
      .car-btn:hover {
        border-color: rgba(var(--accent-rgb), .4);
        color: var(--accent);
      }
      .car-dots {
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .car-dot {
        width: 4px;
        height: 4px;
        min-width: 4px;
        min-height: 4px;
        flex-shrink: 0;
        border-radius: 50%;
        background: rgba(var(--accent-rgb), .18);
        cursor: pointer;
        transition: background .2s;
        position: relative;
      }
      .car-dot::before {
        content: '';
        position: absolute;
        inset: -8px;
      }
      .car-dot.on {
        background: var(--text);
      }

      .project-actions {
        display: flex;
        gap: 0.6rem;
        align-items: center;
        justify-content: flex-end;
        min-width: 140px;
      }

      .project-bullets {
        transition: opacity 0.25s ease, max-height 0.25s ease;
      }

      .hero-links {
        display: none;
        gap: 0.5rem;
        margin-top: 0.6rem;
        flex-wrap: wrap;
      }

      .hero-links a {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.95rem;
        border-radius: var(--radius-full);
        border: 1px solid var(--accent-muted);
        background: var(--surface);
        color: var(--accent);
        font-size: var(--text-sm);
        text-decoration: none;
        transition: border-color 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
      }

      .hero-links a:hover {
        border-color: rgba(var(--accent-rgb), 0.5);
        box-shadow: 0 0 14px rgba(var(--accent-rgb), 0.2);
      }

      .spotify-line {
        margin: 3rem 0 2rem;
        font-size: 0.82rem;
        color: var(--muted);
        font-family: 'Inter', sans-serif;
        letter-spacing: 0.01em;
        transition: opacity 0.3s ease;
        position: relative;
      }

      .spotify-line.not-playing {
        opacity: 0.5;
      }

      .spotify-line.spotify-fade-out {
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      .spotify-inline {
        display: inline-flex;
        align-items: center;
        vertical-align: middle;
        gap: 6px;
        white-space: nowrap;
      }

      .spotify-chevron {
        display: none;
      }

      .spotify-chevron::before {
        content: '';
        display: block;
        width: 5px;
        height: 5px;
        border-right: 1.5px solid var(--muted);
        border-bottom: 1.5px solid var(--muted);
        transform: rotate(45deg);
        margin: 4px auto 0;
      }

      .spotify-expand-hint {
        position: absolute;
        left: 50%;
        bottom: calc(100% + 4px);
        transform: translateX(-50%) translateY(2px);
        font-size: 0.58rem;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(var(--accent-rgb), 0.65);
        white-space: nowrap;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.4s ease, transform 0.3s ease;
      }

      .spotify-expand-hint.visible {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      .spotify-expand-hint.fade-out {
        opacity: 0;
        transform: translateX(-50%) translateY(-2px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }

      .spotify-line.history-open .spotify-expand-hint {
        opacity: 0 !important;
      }

      .spotify-logo-wrap {
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
        position: relative;
      }

      .spotify-logo {
        width: 20px;
        height: 20px;
        color: var(--accent);
      }

      .spotify-line.playing .spotify-logo {
        animation: spin 3s linear infinite;
      }

      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      @media (prefers-reduced-motion: reduce) {
        .spotify-line.playing .spotify-logo {
          animation: none;
        }
      }

      .spotify-line a {
        color: var(--accent);
        text-decoration: none;
        font-style: italic;
      }

      .spotify-line a:hover {
        opacity: 0.8;
      }

      .spotify-marquee-wrap {
        display: inline-block;
        max-width: 220px;
        overflow: hidden;
        vertical-align: bottom;
        mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
        -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
      }

      .spotify-marquee {
        display: inline-block;
        white-space: nowrap;
        animation: marquee 12s linear infinite;
      }

      @keyframes marquee {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      @media (prefers-reduced-motion: reduce) {
        .spotify-marquee {
          animation: none;
        }
      }

      .spotify-progress-row {
        display: inline-flex;
        align-items: center;
        vertical-align: middle;
        margin-left: 10px;
      }

      .spotify-time {
        font-size: 0.7rem;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        opacity: 0.7;
        margin-left: 4px;
      }

      .spotify-progress {
        display: inline-block;
        width: 60px;
        height: 2px;
        background: rgba(var(--accent-rgb), 0.12);
        border-radius: 1px;
        overflow: hidden;
        vertical-align: middle;
        margin: 0 5px;
      }

      .spotify-progress-bar,
      .spotify-mini-bar {
        display: block;
        height: 100%;
        background: var(--accent);
        border-radius: 1px;
        width: 0%;
        transition: width 1s linear;
      }

      /* Mini player - hidden by default, shown on hover */
      .spotify-mini-player {
        position: absolute;
        left: 20%;
        top: 100%;
        margin-top: 6px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(4px);
        transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
        z-index: 10;
      }

      .spotify-line.mini-hover .spotify-mini-player {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      .spotify-line.history-open .spotify-mini-player {
        top: auto;
        bottom: 100%;
        margin-top: 0;
        margin-bottom: 6px;
      }

      .spotify-mini-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: var(--surface-solid);
        border: none;
        border-radius: var(--radius-md);
        text-decoration: none !important;
        color: var(--text);
        font-style: normal !important;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(12px);
        min-width: 280px;
      }

      .spotify-mini-cover {
        width: 56px;
        height: 56px;
        border-radius: 6px;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      }

      .spotify-mini-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
      }

      .spotify-mini-track {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--accent);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .spotify-mini-artist {
        font-size: 0.78rem;
        color: rgba(var(--accent-rgb), 0.6);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .spotify-mini-progress-wrap {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 4px;
      }

      .spotify-mini-progress-wrap .spotify-time {
        font-size: 0.62rem;
        opacity: 0.5;
      }

      .spotify-mini-progress {
        flex: 1;
        height: 2px;
        background: rgba(var(--accent-rgb), 0.12);
        border-radius: 1px;
        overflow: hidden;
      }

      .spotify-history {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                    opacity 0.4s ease,
                    margin 0.3s ease;
        margin-top: 0;
        border-radius: var(--radius-md);
      }

      .spotify-line.history-open .spotify-history {
        max-height: 500px;
        opacity: 1;
        margin-top: 10px;
      }

      .spotify-history-label {
        display: block;
        font-size: 0.65rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
        padding: 14px 16px 0;
        margin-bottom: 10px;
      }

      .spotify-history-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 16px;
        text-decoration: none;
        color: var(--text);
        border-radius: var(--radius-sm);
        transition: background 0.2s ease,
                    transform 0.2s ease,
                    opacity 0.4s ease;
        opacity: 0;
        transform: translateY(6px);
      }

      .spotify-history-item:last-child {
        padding-bottom: 14px;
      }

      .spotify-line.history-open .spotify-history-item {
        opacity: 1;
        transform: translateY(0);
        transition-delay: calc(var(--i, 0) * 60ms);
      }

      .spotify-history-item:hover {
        background: rgba(var(--accent-rgb), 0.06);
      }

      .spotify-history-idx {
        font-size: 0.7rem;
        color: rgba(var(--accent-rgb), 0.3);
        width: 14px;
        text-align: right;
        flex-shrink: 0;
        font-variant-numeric: tabular-nums;
      }

      .spotify-history-cover {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .spotify-history-item:hover .spotify-history-cover {
        transform: scale(1.08);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
      }

      .spotify-history-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
      }

      .spotify-history-track {
        font-size: 0.8rem;
        color: var(--text);
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .spotify-history-artist {
        font-size: 0.7rem;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .hero-tagline {
        margin: 0.6rem 0 0;
        color: var(--text);
        font-size: 1.05rem;
        max-width: 560px;
        line-height: 1.75;
        transition: opacity 0.2s ease;
      }
      body.lang-switching .hero-tagline {
        opacity: 0;
      }

      .hero-tagline.secondary {
        margin-top: 0.25rem;
        color: var(--muted);
      }

      .hero-about {
        margin: 1rem 0 0;
        color: var(--text-soft);
        font-size: 0.95rem;
        max-width: 560px;
        line-height: 1.75;
        transition: opacity 0.2s ease;
      }

      .terminal-window {
        background: transparent;
        border: 1px solid rgba(var(--accent-rgb), 0.15);
        border-radius: var(--radius-md);
        padding: 0.9rem 1.1rem;
        max-width: 480px;
        margin: 1.2rem 0 0;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.72rem;
        font-weight: 400;
        line-height: 1.8;
        overflow-x: auto;
        word-break: break-word;
      }


      .hero-about .word-gen {
        display: inline;
        opacity: 0;
        filter: blur(4px);
        transition: opacity 0.4s ease, filter 0.4s ease;
      }

      .hero-about .word-gen.revealed {
        opacity: 1;
        filter: blur(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-about .word-gen { opacity: 1; filter: none; transition: none; }
      }

      html.light .terminal-window {
        border-color: rgba(var(--accent-rgb), 0.2);
      }

      .terminal-dots {
        display: flex;
        gap: 0.32rem;
        margin-bottom: 0.65rem;
      }

      .dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
      }

      .dot-red { background: #ff5f57; }
      .dot-yellow { background: #febc2e; }
      .dot-green { background: #28c840; }

      .terminal-body {
        display: flex;
        flex-direction: column;
        max-height: 220px;
        overflow-y: auto;
        scrollbar-width: none;
      }

      .terminal-body::-webkit-scrollbar { display: none; }

      .terminal-line.term-hidden {
        opacity: 0;
        transform: translateY(4px);
      }

      .terminal-line.term-visible {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 0.25s var(--ease-out), transform 0.3s var(--ease-spring);
      }

      .terminal-line {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        white-space: normal;
        word-break: break-word;
      }

      .terminal-prompt {
        color: rgba(var(--accent-rgb), 0.7);
        flex-shrink: 0;
      }

      .terminal-cmd {
        color: var(--text-soft);
      }

      html.light .terminal-cmd {
        color: #4a4a4a;
      }

      .terminal-hash {
        color: rgba(var(--accent-rgb), 0.5);
        flex-shrink: 0;
      }

      .terminal-text {
        color: var(--text-soft);
      }

      html.light .terminal-text {
        color: #4a4a4a;
      }

      .terminal-stats {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.25rem 0.45rem;
      }

      .term-stat {
        color: var(--text-soft);
      }

      .term-stat-num {
        color: var(--accent);
        font-weight: 600;
      }

      .term-stat-sep {
        color: var(--muted);
      }

      .terminal-comment {
        color: var(--muted);
      }

      .terminal-cursor {
        display: inline-block;
        width: 7px;
        height: 0.85em;
        background: var(--accent);
        animation: terminal-blink 1.2s step-end infinite;
      }

      @keyframes terminal-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      @media (prefers-reduced-motion: reduce) {
        .terminal-cursor { animation: none; }
      }

      .term-input {
        background: none;
        border: none;
        outline: none;
        color: var(--text-soft);
        font-family: inherit;
        font-size: inherit;
        font-weight: inherit;
        line-height: inherit;
        padding: 0;
        margin: 0;
        width: 100%;
        caret-color: var(--accent);
      }

      html.light .term-input { color: #4a4a4a; }

      .term-input::placeholder {
        color: var(--muted);
        opacity: 0.4;
      }

      .term-output {
        color: var(--text-soft);
        white-space: pre-wrap;
        word-break: break-word;
      }

      .term-output a {
        color: var(--accent);
        background-image: none;
      }

      body.lang-switching .hero-about {
        opacity: 0;
      }

      .connect-footer {
        text-align: center;
        padding: 3rem 0 2rem;
      }

      .connect-tagline {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 2rem;
        font-style: italic;
        color: var(--text);
        margin: 0 0 1.2rem;
      }

      .connect-links {
        display: flex;
        justify-content: center;
        gap: 0.8rem;
        flex-wrap: wrap;
      }

      .mini-map {
        margin-top: 2.5rem;
        display: flex;
        justify-content: center;
      }

      .mini-map-container {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow: hidden;
        border-radius: var(--radius-md);
      }

      .mini-map-img {
        width: 280px;
        height: auto;
        border-radius: var(--radius-md);
        opacity: 0.7;
        filter: var(--map-filter, none);
      }

      .mini-map-light {
        display: none;
      }

      html.light .mini-map-dark {
        display: block;
        filter: var(--map-filter-light, invert(1));
      }

      html.light .mini-map-light {
        display: none;
      }

      .mini-map-dot {
        position: absolute;
        top: 48%;
        left: 43%;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
      }

      .mini-map-dot::before {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        border: 1.5px solid var(--accent);
        opacity: 0;
        animation: map-ping 2s ease-out infinite;
      }

      .mini-map-dot::after {
        content: '';
        position: absolute;
        inset: -10px;
        border-radius: 50%;
        border: 1px solid var(--accent);
        opacity: 0;
        animation: map-ping 2s ease-out infinite 0.4s;
