      }

      .sec-title {
        font-family: "Inter", system-ui, sans-serif;
        font-size: var(--text-xl);
        font-weight: 600;
        color: var(--text);
        letter-spacing: -0.01em;
        margin-bottom: var(--space-8);
      }

      .timeline {
        position: relative;
        padding-left: 1.4rem;
      }

      .timeline::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.5rem;
        bottom: 0;
        width: 1px;
        background: linear-gradient(to bottom, rgba(var(--accent-rgb), 0.35), transparent);
      }

      .tl-item {
        position: relative;
        padding-bottom: 2.4rem;
      }

      .tl-item:last-child {
        padding-bottom: 0;
      }

      .tl-item::before {
        content: '';
        position: absolute;
        left: -1.4rem;
        top: 0.55rem;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        transform: translateX(-4px);
        background: rgba(var(--accent-rgb), 0.25);
        border: 1px solid rgba(var(--accent-rgb), 0.45);
        transition: background 0.3s, box-shadow 0.3s;
      }

      .tl-item.now::before {
        background: var(--accent);
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(var(--accent-rgb), 0.15), 0 0 12px rgba(var(--accent-rgb), 0.4);
      }

      .tl-period {
        font-size: 0.68rem;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        letter-spacing: 0.05em;
        color: var(--muted);
        margin-bottom: 0.25rem;
      }

      .tl-role {
        font-size: 0.98rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.15rem;
      }

      .tl-org {
