      .scroll-line {
        position: fixed;
        top: 0;
        left: 0;
        width: 2px;
        height: 100vh;
        height: 100dvh;
        z-index: 500;
        pointer-events: none;
        background: rgba(255, 255, 255, 0.04);
        opacity: 0;
        transition: opacity 0.4s ease;
      }
      .scroll-line-fill {
        width: 100%;
        height: 0%;
        background: linear-gradient(
          to bottom,
          rgba(var(--accent-rgb), 0.35) 0%,
          rgba(var(--accent-rgb), 0.5) 40%,
          rgba(var(--accent-rgb), 0.4) 100%
        );
        position: relative;
      }
      .scroll-line-fill::after {
        content: '';
        position: absolute;
        bottom: -3px;
        left: 50%;
        transform: translateX(-50%);
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: rgba(var(--accent-rgb), 0.7);
        box-shadow: 0 0 6px 2px rgba(var(--accent-rgb), 0.5), 0 0 12px 4px rgba(var(--accent-rgb), 0.25);
      }
      @media (max-width: 1169px) {
        .scroll-line { display: none; }
      }

      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: var(--noise-opacity);
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 256px 256px;
      }

      .project-card,
      .meta-card {
        position: relative;
        padding: 0.8rem;
        margin-left: -0.8rem;
        margin-right: -0.8rem;
        border-radius: 8px;
        border: 1px solid transparent;
        transition: background 0.3s var(--ease-out), border-color 0.3s var(--ease-out);
      }

      .project-card::before,
      .meta-card::before {
        content: '';
        position: absolute;
        inset: -1px;
        border-radius: inherit;
        padding: 1px;
        background: conic-gradient(
          from var(--border-angle, 0deg),
          transparent 40%,
          rgba(var(--accent-rgb), 0.5) 50%,
          transparent 60%
        );
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
      }

      .project-card:hover::before,
      .meta-card:hover::before {
        opacity: 1;
        animation: border-spin 3s linear infinite;
      }

      @keyframes border-spin {
        to { --border-angle: 360deg; }
      }

      @property --border-angle {
        syntax: "<angle>";
        initial-value: 0deg;
        inherits: false;
      }

      .project-card:hover,
      .meta-card:hover {
        background: var(--card-hover);
      }


      h2 {
        position: relative;
      }

      .section-revealed h2 {
        animation: heading-fade 0.6s var(--ease-spring) forwards;
      }

      @keyframes heading-fade {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .section-revealed .project-card,
      .section-revealed .meta-card,
      .section-revealed .tl-item {
        opacity: 0;
        transform: translateY(16px) scale(0.97);
        animation: card-stagger 0.5s var(--ease-spring) forwards;
      }

      .section-revealed .project-card:nth-child(2) { animation-delay: 0.06s; }
      .section-revealed .project-card:nth-child(3) { animation-delay: 0.12s; }
      .section-revealed .project-card:nth-child(4) { animation-delay: 0.18s; }
      .section-revealed .project-card:nth-child(5) { animation-delay: 0.24s; }
      .section-revealed .project-card:nth-child(6) { animation-delay: 0.30s; }
      .section-revealed .project-card:nth-child(7) { animation-delay: 0.36s; }

      .section-revealed .tl-item:nth-child(2) { animation-delay: 0.06s; }
      .section-revealed .tl-item:nth-child(3) { animation-delay: 0.12s; }
      .section-revealed .tl-item:nth-child(4) { animation-delay: 0.18s; }
      .section-revealed .tl-item:nth-child(5) { animation-delay: 0.24s; }

      .section-revealed .meta-card:nth-child(2) { animation-delay: 0.06s; }
      .section-revealed .meta-card:nth-child(3) { animation-delay: 0.12s; }
      .section-revealed .meta-card:nth-child(4) { animation-delay: 0.18s; }
      .section-revealed .meta-card:nth-child(5) { animation-delay: 0.24s; }
      .section-revealed .meta-card:nth-child(6) { animation-delay: 0.30s; }
      .section-revealed .meta-card:nth-child(7) { animation-delay: 0.36s; }
      .section-revealed .meta-card:nth-child(8) { animation-delay: 0.42s; }

      #education.section-revealed .meta-card {
        animation: card-stagger 0.5s var(--ease-spring) forwards, edu-glow 1.6s var(--ease-out) 0.2s forwards;
      }

      #connect.section-revealed .connect-links .cta-btn {
        opacity: 0;
        transform: translateY(16px) scale(0.97);
        animation: card-stagger 0.5s var(--ease-spring) forwards;
      }
      #connect.section-revealed .connect-links .cta-btn:nth-child(1) { animation-delay: 0.08s; }
      #connect.section-revealed .connect-links .cta-btn:nth-child(2) { animation-delay: 0.16s; }
      #connect.section-revealed .connect-links .cta-btn:nth-child(3) { animation-delay: 0.24s; }

      @keyframes card-stagger {
        to { opacity: 1; transform: translateY(0) scale(1); }
      }

      @keyframes edu-glow {
        0%   { border-color: rgba(var(--accent-rgb), 0); }
        30%  { border-color: rgba(var(--accent-rgb), 0.4); }
        100% { border-color: rgba(var(--accent-rgb), 0.08); }
      }


      @media (hover: hover) and (prefers-reduced-motion: no-preference) {
        body.cursor-active, body.cursor-active * { cursor: none !important; }
      }

      .cursor-dot {
        position: fixed;
        width: 5px;
        height: 5px;
        background: var(--accent);
        border-radius: 50%;
        pointer-events: none;
        z-index: 10000;
        transform: translate(-50%, -50%);
        opacity: 0;
        transition: opacity 0.3s ease, transform 0.2s ease;
        will-change: transform;
      }

      .cursor-trail {
        position: fixed;
        width: 4px;
        height: 4px;
        background: var(--accent);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        opacity: 0;
        will-change: transform, opacity;
