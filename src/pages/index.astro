            if (!pat) return { lines: ['grep: missing pattern'], cls: 'err' };
            if (!stdin) return { lines: ['grep: reads a pipe — try: projects | grep rust'], cls: 'err' };
            let re; try { re = new RegExp(pat.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'i'); } catch { re = null; }
