            scroll.style.scrollBehavior = 'auto';
            scroll.scrollLeft = sw;
            scroll.style.scrollBehavior = '';
            syncDots();
            startAutoplay();
          }
        };
        hintNext();
      };

      const recsSection = document.getElementById('recommendations');
      if (recsSection) {
        const hintObs = new IntersectionObserver((entries) => {
