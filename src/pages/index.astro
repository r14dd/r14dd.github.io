---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profiles } from '../data/profile-i18n';
import {
  buildExperience,
  buildProjects,
  buildTeaching,
  buildEducation,
  buildSkills,
  buildRecommendations,
  buildConnect,
} from '../lib/builders';

const profile = profiles.en;
// Mirror of the runtime wrapNum in applyLanguage — keep in sync.
const wrapStatNum = (s: string) =>
  s.replace(/^([\d.,+Kk]+)/, '<span class="term-stat-num">$1</span>');
const metaTitle = `${profile.hero.name} — Portfolio`;
const metaDescription =
  'Riad Mukhtarov — AI & software engineer working in Rust and Python. Building distributed systems at ABB, previously taught CS at SUNY Buffalo.';
const structuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.hero.name,
  alternateName: ['Riad Muxtarov', 'r14dd'],
  jobTitle: 'AI/Software Engineer',
  url: 'https://riad.cc',
  sameAs: [profile.links.linkedin, profile.links.github, 'https://crates.io/users/r14dd'],
  email: `mailto:${profile.email}`,
});
---

<BaseLayout
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  structuredData={structuredData}
  lang="en"
>
  {/* EN only — RU/AZ are fetched from /i18n/<lang>.json on first switch. */}
  <script type="application/json" id="i18n-data" set:html={JSON.stringify({ en: profiles.en })} />

  <div class="lang-switcher" aria-label="Controls">
    <button
      class="cmd-trigger"
      id="cmd-trigger"
      type="button"
      aria-label="Open command palette (⌘K)"
    >
      <span class="cmd-trigger-label">⌘K</span>
      <svg
        class="cmd-trigger-icon"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        ><circle cx="6.5" cy="6.5" r="4.5"></circle><path d="M10 10l3 3"></path></svg
      >
    </button>
    <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Switch to light mode">
      <span class="theme-icon" aria-hidden="true">☀️</span>
    </button>
    <button
      class="lang-toggle"
      id="lang-toggle"
      type="button"
      aria-haspopup="menu"
      aria-expanded="false"
    >
      <span class="lang-globe" aria-hidden="true">
        <svg
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="8" cy="8" r="6"></circle>
          <path d="M8 2C7 4 6.5 6 6.5 8s.5 4 1.5 6M8 2c1 2 1.5 4 1.5 6S9 12 8 14"></path>
          <path d="M2.5 5.5h11M2.5 10.5h11"></path>
        </svg>
      </span>
      <span class="lang-label" id="lang-current">English</span>
      <span class="lang-caret" aria-hidden="true">▾</span>
    </button>
    <div class="lang-menu" id="lang-menu" role="menu" aria-label="Select language">
      <button type="button" role="menuitemradio" aria-checked="true" data-lang="en">English</button>
      <button type="button" role="menuitemradio" aria-checked="false" data-lang="ru">Русский</button
      >
      <button type="button" role="menuitemradio" aria-checked="false" data-lang="az"
        >Azərbaycanca</button
      >
    </div>
  </div>

  <div class="pull-indicator" id="pull-indicator" aria-hidden="true">
    <svg
      viewBox="0 0 16 16"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"><path d="M8 2v12M5 5l3-3 3 3"></path></svg
    >
  </div>

  <nav class="side-nav" id="side-nav">
    <a href="#education">{profile.labels.nav.education}</a>
    <a href="#experience">{profile.labels.nav.experience}</a>
    <a href="#projects">{profile.labels.nav.projects}</a>
    <a href="#skills">{profile.labels.nav.skills}</a>
    <a href="#teaching">{profile.labels.nav.teaching}</a>
    <a href="#recommendations">{profile.labels.nav.recommendations}</a>
    <a href="#connect">{profile.labels.nav.connect}</a>
  </nav>

  <aside class="side-links">
    <span class="mono" id="side-links-heading">{profile.labels.links.heading}</span>
    <a href={profile.links.linkedin} target="_blank" rel="noopener"
      >{profile.labels.links.linkedin}</a
    >
    <a href={profile.links.github} target="_blank" rel="noopener">{profile.labels.links.github}</a>
    <a href={`mailto:${profile.email}`}>Email</a>
    <a href={profile.links.resume} target="_blank" rel="noopener">{profile.labels.links.resume}</a>
  </aside>

  <main class="content" id="main-content">
    <section>
      <p class="hero-eyebrow" id="hero-eyebrow">{profile.labels.heroEyebrow}</p>
      <h1 id="hero-name">{profile.hero.name}</h1>
      <p class="hero-about" id="hero-about">{profile.about}</p>

      <div class="terminal-window" aria-label="Current work terminal">
        <div class="terminal-dots" aria-hidden="true">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <div class="terminal-body" data-lenis-prevent>
          <div class="terminal-line">
            <span class="terminal-prompt">→</span>
            <span class="terminal-cmd">whoami</span>
          </div>
          <div class="terminal-line">
            <span class="terminal-text" id="term-role1">{profile.labels.terminal.role1}</span>
          </div>
          <div class="terminal-line">
            <span class="terminal-text" id="term-role2">{profile.labels.terminal.role2}</span>
          </div>
          <div class="terminal-line">
            <span class="terminal-prompt">→</span>
            <span class="terminal-cmd">stats</span>
          </div>
          <div class="terminal-line terminal-stats">
            <span class="term-stat" id="term-stat1"
              ><Fragment set:html={wrapStatNum(profile.labels.terminal.stat1)} /></span
            >
            <span class="term-stat-sep">·</span>
            <span class="term-stat" id="term-stat2"
              ><Fragment set:html={wrapStatNum(profile.labels.terminal.stat2)} /></span
            >
            <span class="term-stat-sep">·</span>
            <span class="term-stat" id="term-stat3"
              ><Fragment set:html={wrapStatNum(profile.labels.terminal.stat3)} /></span
            >
          </div>
          <div class="terminal-line" id="term-input-line">
            <span class="terminal-prompt">→</span>
            <span class="terminal-cursor" aria-hidden="true"></span>
          </div>
        </div>
      </div>

      <div class="hero-links">
        <a href={profile.links.linkedin} target="_blank" rel="noopener"
          ><svg class="cta-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path></svg
          >{profile.labels.links.linkedin}</a
        >
        <a href={profile.links.github} target="_blank" rel="noopener"
          ><svg class="cta-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path></svg
          >{profile.labels.links.github}</a
        >
        <a href={`mailto:${profile.email}`}
          ><svg
            class="cta-icon"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
              d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
          >Email</a
        >
        <a href={profile.links.resume} target="_blank" rel="noopener"
          ><svg
            class="cta-icon"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline
              points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line
              x1="16"
              y1="17"
              x2="8"
              y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg
          >{profile.labels.links.resume}</a
        >
      </div>
    </section>

    <div class="spotify-line" id="spotify-line"></div>

    <section id="education" class="section-block" data-label={profile.labels.headings.education}>
      <Fragment set:html={buildEducation(profile)} />
    </section>

    <section
      id="experience"
      class="section-block exp-section"
      data-label={profile.labels.headings.experience}
    >
      <Fragment set:html={buildExperience(profile)} />
    </section>

    <section
      id="projects"
      class="section-block proj-section"
      data-label={profile.labels.headings.projects}
    >
      <Fragment set:html={buildProjects(profile)} />
    </section>

    <section
      id="skills"
      class="section-block skill-section"
      data-label={profile.labels.headings.skills}
    >
      <Fragment set:html={buildSkills(profile)} />
    </section>

    <section id="teaching" class="section-block" data-label={profile.labels.headings.teaching}>
      <Fragment set:html={buildTeaching(profile)} />
    </section>

    <section
      id="recommendations"
      class="section-block"
      data-label={profile.labels.headings.recommendations}
    >
      <Fragment set:html={buildRecommendations(profile)} />
    </section>

    <section id="connect" class="connect-footer">
      <Fragment set:html={buildConnect(profile)} />
    </section>
  </main>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Section navigation">
    <button class="mobile-nav-pill" id="mobile-nav-pill" type="button">
      <span class="mobile-nav-label" id="mobile-nav-label"></span>
      <span class="mobile-nav-caret">&#9662;</span>
    </button>
    <div class="mobile-nav-menu" id="mobile-nav-menu">
      <a href="#education">{profile.labels.nav.education}</a>
      <a href="#experience">{profile.labels.nav.experience}</a>
      <a href="#projects">{profile.labels.nav.projects}</a>
      <a href="#skills">{profile.labels.nav.skills}</a>
      <a href="#teaching">{profile.labels.nav.teaching}</a>
      <a href="#recommendations">{profile.labels.nav.recommendations}</a>
      <a href="#connect">{profile.labels.nav.connect}</a>
    </div>
  </nav>

  <div class="toast" id="toast" aria-live="polite"></div>

  <div class="cmd-backdrop" id="cmd-backdrop" aria-hidden="true"></div>
  <div
    class="cmd-palette"
    id="cmd-palette"
    role="dialog"
    aria-modal="true"
    aria-label="Command palette"
    aria-hidden="true"
  >
    <div class="cmd-input-wrap">
      <span class="cmd-search-icon" aria-hidden="true">
        <svg
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          ><circle cx="6.5" cy="6.5" r="4.5"></circle><path d="M10 10l3 3"></path></svg
        >
      </span>
      <input
        type="text"
        class="cmd-input"
        id="cmd-input"
        placeholder="Search or jump to..."
        autocomplete="off"
        spellcheck="false"
        aria-label="Command search"
        role="combobox"
        aria-expanded="false"
        aria-controls="cmd-results"
        aria-activedescendant=""
      />
      <span class="cmd-kbd">ESC</span>
    </div>
    <div class="cmd-results" id="cmd-results" role="listbox" data-lenis-prevent></div>
    <div class="cmd-footer">
      <span class="cmd-footer-hint"><span class="cmd-kbd">↑↓</span> navigate</span>
      <span class="cmd-footer-hint"><span class="cmd-kbd">↵</span> select</span>
      <span class="cmd-footer-hint"><span class="cmd-kbd">?</span> shortcuts</span>
      <span class="cmd-footer-hint"><span class="cmd-kbd">ESC</span> close</span>
    </div>
  </div>

  <div class="kbd-backdrop" id="kbd-backdrop" aria-hidden="true"></div>
  <div
    class="kbd-overlay"
    id="kbd-overlay"
    role="dialog"
    aria-modal="true"
    aria-label="Keyboard shortcuts"
    aria-hidden="true"
    tabindex="-1"
  >
    <div class="kbd-head">
      <span>Keyboard shortcuts</span>
      <span class="cmd-kbd">ESC</span>
    </div>
    <div class="kbd-grid">
      <div class="kbd-row">
        <span class="kbd-desc">Command palette</span><span class="kbd-keys"
          ><kbd>⌘</kbd><kbd>K</kbd></span
        >
      </div>
      <div class="kbd-row">
        <span class="kbd-desc">This menu</span><span class="kbd-keys"><kbd>?</kbd></span>
      </div>
      <div class="kbd-row">
        <span class="kbd-desc">Find in page</span><span class="kbd-keys"
          ><kbd>⌘</kbd><kbd>F</kbd></span
        >
      </div>
      <div class="kbd-row">
        <span class="kbd-desc">Jump to section</span><span class="kbd-keys"
          ><kbd>g</kbd><span class="kbd-then">then</span><kbd>e</kbd><kbd>p</kbd><kbd>s</kbd><kbd
            >t</kbd
          ><kbd>d</kbd><kbd>r</kbd><kbd>m</kbd><kbd>c</kbd></span
        >
      </div>
      <div class="kbd-row">
        <span class="kbd-desc">Toggle theme</span><span class="kbd-keys"><kbd>\</kbd></span>
      </div>
      <div class="kbd-row">
        <span class="kbd-desc">Close overlays</span><span class="kbd-keys"><kbd>esc</kbd></span>
      </div>
    </div>
  </div>

  <div class="easter-overlay" id="easter-overlay" aria-hidden="true"></div>
  <div class="proj-backdrop" id="proj-backdrop" aria-hidden="true"></div>
  <div class="find-nav-bar" id="find-nav-bar" aria-hidden="true">
    <button class="find-nav-btn" id="find-nav-prev" type="button" aria-label="Previous match"
      ><svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"><path d="M10 11L6 7l4-4"></path></svg
      ></button
    >
    <span class="find-nav-count" id="find-nav-count" aria-live="polite"></span>
    <button class="find-nav-btn" id="find-nav-next" type="button" aria-label="Next match"
      ><svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"><path d="M6 11l4-4-4-4"></path></svg
      ></button
    >
    <button class="find-nav-close" id="find-nav-close" type="button" aria-label="Close"
      ><svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8"></path></svg
      ></button
    >
  </div>

  <div
    class="proj-modal"
    id="proj-modal"
    role="dialog"
    aria-modal="true"
    aria-label="Project detail"
    aria-hidden="true"
  >
    <button class="proj-close" id="proj-close" type="button" aria-label="Close project detail">
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8"></path></svg
      >
    </button>
    <div class="proj-modal-card" id="proj-modal-card" data-lenis-prevent></div>
  </div>

  <script>
    // Page orchestrator: every feature lives in src/lib/client/*; this script
    // only calls their inits in the original top-to-bottom order, which
    // preserves listener registration order (palette → shortcuts → konami on
    // document keydown, mobile-nav → lang-menu on document click).
    import * as sfx from '../lib/client/sfx';
    import { initSpotify } from '../lib/client/spotify';
    import { fetchBadges } from '../lib/client/badges';
    import { initHeroReveal } from '../lib/client/hero-reveal';
    import { initTerminalBoot, initTerminal } from '../lib/client/terminal';
    import { initNav } from '../lib/client/nav';
    import { initSimOverlay } from '../lib/client/sim-overlay';
    import { initI18n } from '../lib/client/i18n-runtime';
    import { initTheme } from '../lib/client/theme';
    import { initCmdPalette } from '../lib/client/cmd-palette';
    import { initShortcuts } from '../lib/client/shortcuts';
    import { initProjectModal } from '../lib/client/project-modal';
    import { initGestures } from '../lib/client/gestures';
    import { initAmbient } from '../lib/client/ambient';

    console.log(
      '%criad.cc%c — built with patience, discipline, hunger, focus.\n' +
        '"I am young, I am twenty years old; yet I know nothing of life but despair." — Remarque\n' +
        '"No such thing as a life that\'s better than yours." — J. Cole',
      'font-weight:bold;font-size:14px;color:#818cf8',
      'font-size:12px;color:inherit',
    );

    initHeroReveal();

    initTerminalBoot();

    initTerminal();

    initNav();
    initSimOverlay();
    initI18n();
    sfx.init();

    initTheme();

    initCmdPalette();
    initShortcuts();
    initProjectModal();
    initGestures();

    initSpotify();

    initAmbient();
    fetchBadges();
  </script>
</BaseLayout>
