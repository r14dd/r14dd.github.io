      const wasmXor = async (a, b) => { const w = await loadWasm(); return { dist: w.xor_distance(a >>> 0, b >>> 0) >>> 0, bucket: w.bucket_index(a >>> 0, b >>> 0) >>> 0 }; };
      const wasmHash = async (text) => { const w = await loadWasm(); const bytes = new TextEncoder().encode(text); const n = Math.min(bytes.length, w.input_cap()); const ptr = w.input_ptr(); new Uint8Array(w.memory.buffer, ptr, n).set(bytes.subarray(0, n)); return w.fnv1a32(n) >>> 0; };

