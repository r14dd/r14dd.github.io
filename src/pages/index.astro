      const getCommands = () => {
        const p = window._termProfile || {};
        const email = p.email || 'riad@riad.cc';
        const github = p.links?.github || 'https://github.com/r14dd';
        const resume = p.links?.resume || '/resume.pdf';
        const projectNames = (p.projects || []).map(x => x.name);
        return {
          help: () => { return { lines: [
            '<span class="terminal-text">whoami</span>  <span class="terminal-comment">current roles</span>',
            '<span class="terminal-text">stats</span>   <span class="terminal-comment">quick numbers</span>',
            '<span class="terminal-text">projects</span><span class="terminal-comment"> list projects</span>',
            '<span class="terminal-text">skills</span>  <span class="terminal-comment">top skills</span>',
            '<span class="terminal-text">contact</span> <span class="terminal-comment">get in touch</span>',
            '<span class="terminal-text">resume</span>  <span class="terminal-comment">open resume</span>',
            '<span class="terminal-text">github</span>  <span class="terminal-comment">open GitHub</span>',
            '<span class="terminal-text">fortune</span> <span class="terminal-comment">random wisdom</span>',
            '<span class="terminal-text">clear</span>   <span class="terminal-comment">clear terminal</span>',
