          tail: (args, raw, stdin) => { if (!stdin) return { lines: ['tail: reads a pipe'], cls: 'err' }; let n = 5; const m = raw.match(/(\d+)/); if (m) n = parseInt(m[1], 10); return { lines: stdin.slice(-n) }; },
          wc: (args, raw, stdin) => { if (!stdin) return { lines: ['wc: reads a pipe'], cls: 'err' }; return { lines: [String(stdin.length)] }; },
          man: (args) => {
            const who = (args[0] || 'riad').toLowerCase();
            if (who !== 'riad') return { lines: ['No manual entry for ' + who + '. Try: man riad'], cls: 'muted' };
            return { lines: [
              'RIAD(1)            Personal Manual            RIAD(1)',
              '',
              'NAME',
