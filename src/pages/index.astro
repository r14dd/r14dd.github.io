          .map((x) => x.c);
        if (matchCount > 0) {
          cmdFiltered = [
            { label: `${matchCount} match${matchCount === 1 ? '' : 'es'} on page`, group: 'Find', icon: 'find', action: commitFind },
            ...cmdFiltered,
          ];
        }
      } else {
        cmdFiltered = all;
