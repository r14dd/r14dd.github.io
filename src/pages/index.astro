  <script>
    // @ts-nocheck
    const SCRAMBLE_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%';
    const scrambleText = (el, finalText, duration = 550) => {
      const len = finalText.length;
      const totalFrames = Math.round(duration / 35);
      let frame = 0;
      const id = setInterval(() => {
        el.textContent = Array.from(finalText).map((char, i) => {
          if (char === ' ') return ' ';
          if (frame >= Math.floor((i / len) * totalFrames) + 2) return char;
          return SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)];
        }).join('');
        if (++frame > totalFrames) { el.textContent = finalText; clearInterval(id); }
      }, 35);
    };

    let heroFirstLoad = true;
    const weightReveal = (el, text) => {
      if (heroFirstLoad) {
        heroFirstLoad = false;
        el.textContent = text;
        setTimeout(() => {
          el.style.animation = 'none';
          void el.offsetWidth;
          el.style.animation = 'name-shimmer 6s linear forwards, weight-in 800ms cubic-bezier(0.16, 1, 0.3, 1) both';
        }, 1050);
      } else {
        scrambleText(el, text);
      }
    };

    const i18nEl = document.getElementById("i18n-data");
    const I18N = i18nEl ? JSON.parse(i18nEl.textContent || "{}") : {};
    const languageLabels = {
      en: "English",
      ru: "Русский",
      az: "Azərbaycanca",
      es: "Español",
    };

    const openFromHash = () => {
      const id = window.location.hash.replace("#", "");
      if (!id) return;
      const section = document.getElementById(id);
      if (!section) return;
      section.scrollIntoView({ behavior: "smooth", block: "start" });
    };

    window.addEventListener("hashchange", openFromHash);
    window.addEventListener("load", openFromHash);

    const sections = Array.from(document.querySelectorAll("section[id]"));
    const navLinks = Array.from(document.querySelectorAll(".side-nav a"));
    const dockItems = Array.from(document.querySelectorAll(".dock-item"));
    const dockTrack = document.querySelector(".dock-track");
    const dockIndicator = document.querySelector(".dock-indicator");

    const setDockActive = (id) => {
      const activeItem = dockItems.find(item => item.getAttribute("href") === `#${id}`);
      dockItems.forEach(item => item.classList.remove("active"));
      if (!activeItem || !dockTrack || !dockIndicator) return;
      activeItem.classList.add("active");
      dockIndicator.style.width = activeItem.offsetWidth + "px";
      dockIndicator.style.left = activeItem.offsetLeft + "px";
      const itemCenter = activeItem.offsetLeft + activeItem.offsetWidth / 2;
      dockTrack.scrollTo({ left: itemCenter - dockTrack.offsetWidth / 2, behavior: "smooth" });
    };

    const setActiveLink = () => {
      const scrollPos = window.scrollY + 120;
      let current = sections[0];
      sections.forEach((section) => {
        if (section.offsetTop <= scrollPos) current = section;
      });
      if (window.scrollY + window.innerHeight >= document.body.scrollHeight - 4) {
        current = sections[sections.length - 1];
      }
      navLinks.forEach((link) => link.classList.remove("active"));
      const active = navLinks.find(link => link.getAttribute("href") === `#${current.id}`);
      active?.classList.add("active");
      const pill = document.querySelector(".nav-pill");
      const sideNav = document.querySelector(".side-nav");
      if (pill && active && sideNav) {
        const navRect = sideNav.getBoundingClientRect();
        const linkRect = active.getBoundingClientRect();
        pill.style.top = (linkRect.top - navRect.top + (linkRect.height - 26) / 2) + "px";
        pill.style.opacity = "1";
      }
      setDockActive(current.id);
    };

    const updateProgress = () => {
      const progress = document.getElementById("scroll-progress");
      if (!progress) return;
      const docHeight = document.body.scrollHeight - window.innerHeight;
      const percent = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
      progress.style.height = `${percent}%`;
    };

    const updateNavBlur = () => {
      const nav = document.querySelector(".side-nav");
      const links = document.querySelector(".side-links");
      if (!nav && !links) return;
      const shouldBlur = window.scrollY > 40;
      nav?.classList.toggle("blurred", shouldBlur);
      links?.classList.toggle("blurred", shouldBlur);
    };

    const smoothScrollTo = (el, duration = 480) => {
      const start = window.scrollY;
      const end = el.getBoundingClientRect().top + window.scrollY - 24;
      const startTime = performance.now();
      const easeOutQuart = (t) => 1 - Math.pow(1 - t, 4);
      const step = (now) => {
        const elapsed = Math.min((now - startTime) / duration, 1);
        window.scrollTo(0, start + (end - start) * easeOutQuart(elapsed));
        if (elapsed < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    document.querySelectorAll(".side-nav a, .dock-item").forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const id = link.getAttribute("href")?.replace("#", "");
        if (!id) return;
        const target = document.getElementById(id);
        if (!target) return;
        smoothScrollTo(target);
        history.pushState(null, "", `#${id}`);
      });
    });

    const heroEl = document.querySelector("main > section:first-of-type");
    const updateParallax = () => {
      if (!heroEl) return;
      const scrolled = window.scrollY;
      const h1 = heroEl.querySelector("h1");
      const taglines = heroEl.querySelectorAll(".hero-tagline");
      if (h1) h1.style.transform = `translateY(${scrolled * 0.12}px)`;
      taglines.forEach((t) => { t.style.transform = `translateY(${scrolled * 0.08}px)`; });
    };

    window.addEventListener("scroll", () => {
      setActiveLink();
      updateProgress();
      updateNavBlur();
      updateParallax();
    });
    window.addEventListener("load", () => {
      setActiveLink();
      updateProgress();
      updateNavBlur();
      updateParallax();
    });

    document.querySelectorAll(".simulate-btn").forEach((btn) => {
