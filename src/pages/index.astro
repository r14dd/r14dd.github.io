      const activate = () => {
        const cursorEl = inputLine.querySelector('.terminal-cursor');
        if (cursorEl) cursorEl.remove();

        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'term-input';
        input.setAttribute('autocomplete', 'off');
        input.setAttribute('spellcheck', 'false');
        input.setAttribute('placeholder', 'type help');
        input.setAttribute('aria-label', 'Terminal command input');
        inputLine.appendChild(input);

        const exec = (raw) => {
          const cmd = raw.trim().toLowerCase();
          if (!cmd) return;

          history.unshift(raw.trim());
          histIdx = -1;

          const echoLine = document.createElement('div');
          echoLine.className = 'terminal-line term-visible';
          echoLine.innerHTML = '<span class="terminal-prompt">→</span> <span class="terminal-cmd">' + cmd.replace(/</g, '&lt;') + '</span>';
          termBody.insertBefore(echoLine, inputLine);

          const commands = getCommands();
          if (cmd === 'clear') {
            const keep = [inputLine];
            Array.from(termBody.children).forEach(el => {
              if (!keep.includes(el)) el.remove();
            });
            return;
          }

          const fn = commands[cmd];
          const result = fn ? fn() : { html: '<span class="terminal-text">command not found: ' + cmd.replace(/</g, '&lt;') + '. Type \'help\' for available commands.</span>' };

          if (result != null) {
            if (result && typeof result === 'object' && result.lines) {
              result.lines.forEach(l => {
                const row = document.createElement('div');
                row.className = 'terminal-line term-visible';
                row.innerHTML = l;
                termBody.insertBefore(row, inputLine);
              });
            } else {
              const outLine = document.createElement('div');
              outLine.className = 'terminal-line term-visible';
              if (result && typeof result === 'object' && result.html) {
                outLine.innerHTML = result.html;
              } else {
                outLine.innerHTML = '<span class="terminal-text">' + result + '</span>';
              }
              termBody.insertBefore(outLine, inputLine);
            }
          }

          termBody.scrollTop = termBody.scrollHeight;
        };

        input.addEventListener('keydown', (e) => {
          sfx.tap();
          if (e.key === 'Enter') {
            exec(input.value);
            input.value = '';
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (history.length && histIdx < history.length - 1) {
              histIdx++;
              input.value = history[histIdx];
            }
          } else if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (histIdx > 0) {
              histIdx--;
              input.value = history[histIdx];
            } else {
              histIdx = -1;
              input.value = '';
            }
          }
        });

        const termWindow = termBody.closest('.terminal-window');
        termWindow?.addEventListener('click', (e) => {
          if (e.target.tagName !== 'A') input.focus();
        });
      };

      if (prefersReducedMotion) {
        activate();
      } else {
        window.addEventListener('term-ready', activate, { once: true });
      }
    })();

    const i18nEl = document.getElementById("i18n-data");
