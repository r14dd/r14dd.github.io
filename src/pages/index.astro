            showNav();
          });
        }
      }, { passive: true });

      pill?.addEventListener("click", () => {
        mobileNav.classList.toggle("open");
        if (mobileNav.classList.contains("open")) {
          mobileNav.classList.add("visible");
          clearTimeout(hideTimer);
        }
      });
      mobileMenuLinks.forEach(a => {
        a.addEventListener("click", (e) => {
