          stats: () => {
            const t = p.labels?.terminal || {};
            const wrapNum = (s) => s.replace(/^([\d.,+Kk]+)/, '<span class="term-stat-num">$1</span>');
            return { html: '<span class="terminal-stats" style="display:flex;flex-wrap:wrap;align-items:baseline;gap:0.25rem 0.45rem"><span class="term-stat">' + wrapNum(t.stat1 || '2K+ students taught') + '</span><span class="term-stat-sep">·</span><span class="term-stat">' + wrapNum(t.stat2 || '5+ teams led') + '</span><span class="term-stat-sep">·</span><span class="term-stat">' + wrapNum(t.stat3 || '4+ yrs shipping') + '</span></span>' };
          },
          projects: () => {
            setTimeout(() => {
              document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 400);
            return { lines: projectNames.length ? projectNames.map(n => '<span class="terminal-text">· ' + n + '</span>') : ['<span class="terminal-text">No projects loaded.</span>'] };
          },
          skills: () => { return { lines: [
            '<span class="terminal-text">Rust · Python · Go · Tokio · FastAPI</span>',
            '<span class="terminal-text">Kafka · PostgreSQL · Docker · AWS</span>',
          ] }; },
          contact: () => { return { html: '<span class="terminal-text">' + email + '</span>' }; },
          resume: () => { window.open(resume, '_blank'); return { html: '<span class="terminal-text">Opening resume...</span>' }; },
          github: () => { window.open(github, '_blank'); return { html: '<span class="terminal-text">Opening github.com/r14dd...</span>' }; },
          fortune: () => { return { html: '<span class="terminal-text">' + FORTUNES[Math.floor(Math.random() * FORTUNES.length)] + '</span>' }; },
          clear: () => null,
