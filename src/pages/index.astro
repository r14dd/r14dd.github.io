    const typeH2 = (h2) => {
      if (prefersReduced) return;
      const textNode = Array.from(h2.childNodes).find(n => n.nodeType === 3 && n.textContent.trim());
      if (!textNode) return;
      const text = textNode.textContent;
      const len = text.length;
      const perChar = 400 / len;
      let i = 0;
      textNode.textContent = "";
      const step = () => {
        textNode.textContent = text.slice(0, ++i);
        if (i < len) setTimeout(step, perChar);
      };
      step();
    };

    const getInitials = (name) => name.split(' ').map(w => w[0]).join('');

    let carouselTimer = null;
    let carouselAbort = null;
    const DOT_COUNT = 5;
    const initCarousel = () => {
      clearInterval(carouselTimer);
      if (carouselAbort) carouselAbort.abort();
      carouselAbort = new AbortController();
      const signal = carouselAbort.signal;
      const scroll = document.getElementById('testi-scroll');
      const dotsEl = document.getElementById('car-dots');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');
      if (!scroll || !dotsEl) return;

      const cards = scroll.querySelectorAll('.testi-card');
      const count = cards.length;
      dotsEl.innerHTML = '';
      for (let i = 0; i < DOT_COUNT; i++) {
        const d = document.createElement('div');
        d.className = 'car-dot' + (i === 0 ? ' on' : '');
        d.addEventListener('click', () => {
          const cardIdx = Math.round(i / (DOT_COUNT - 1) * (count - 1));
          scrollTo(cardIdx);
        }, { signal });
        dotsEl.appendChild(d);
      }

      const scrollTo = (i) => {
        const card = cards[i];
        if (!card) return;
        scroll.scrollTo({ left: card.offsetLeft - scroll.offsetLeft, behavior: 'smooth' });
      };

      const cardToDot = (cardIdx) => Math.round(cardIdx / (count - 1) * (DOT_COUNT - 1));

      const syncDots = () => {
        const sl = scroll.scrollLeft;
        const cw = cards[0]?.offsetWidth || 1;
        const gap = parseFloat(getComputedStyle(scroll).gap) || 0;
        const active = Math.round(sl / (cw + gap));
        const dotIdx = cardToDot(active);
        dotsEl.querySelectorAll('.car-dot').forEach((d, j) => d.classList.toggle('on', j === dotIdx));
        return active;
      };

      let scrollTick = false;
      scroll.addEventListener('scroll', () => {
        if (scrollTick) return;
        scrollTick = true;
        requestAnimationFrame(() => { syncDots(); scrollTick = false; });
      }, { passive: true, signal });

      prevBtn?.addEventListener('click', () => { const cur = syncDots(); scrollTo((cur - 1 + count) % count); }, { signal });
      nextBtn?.addEventListener('click', () => { const cur = syncDots(); scrollTo((cur + 1) % count); }, { signal });

      const wrap = scroll.closest('[aria-roledescription="carousel"]');
      if (wrap) {
        wrap.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') { e.preventDefault(); const cur = syncDots(); scrollTo((cur - 1 + count) % count); }
          else if (e.key === 'ArrowRight') { e.preventDefault(); const cur = syncDots(); scrollTo((cur + 1) % count); }
        }, { signal });
      }

      carouselTimer = setInterval(() => { const cur = syncDots(); scrollTo((cur + 1) % count); }, 7000);
    };

