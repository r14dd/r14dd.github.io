---
// Standalone birthday page — no layout needed
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
  <title>С Днём Рождения, Джамил! 🎂</title>
  <meta name="robots" content="noindex, nofollow" />
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Nunito:wght@400;700;900&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Nunito', sans-serif;
      overflow: hidden;
      background: #0a0a2e;
      color: #fff;
      height: 100dvh;
      width: 100vw;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }

    canvas#confetti {
      position: fixed;
      inset: 0;
      z-index: 1000;
      pointer-events: none;
    }

    .stars {
      position: fixed;
      inset: 0;
      z-index: 0;
    }
    .stars span {
      position: absolute;
      border-radius: 50%;
      background: #fff;
      animation: twinkle var(--d, 3s) ease-in-out infinite alternate;
    }
    @keyframes twinkle {
      0% { opacity: 0.2; transform: scale(0.8); }
      100% { opacity: 1; transform: scale(1.2); }
    }

    .screen {
      position: fixed;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 10;
      transition: opacity 0.6s, transform 0.6s;
      padding: 1.5rem;
    }
    .screen.hidden {
      opacity: 0;
      pointer-events: none;
      transform: scale(0.95);
    }

    /* ===== INTRO ===== */
    #intro h1 {
      font-family: 'Comfortaa', sans-serif;
      font-size: clamp(2rem, 8vw, 4.5rem);
      text-align: center;
      background: linear-gradient(135deg, #ff6b6b, #feca57, #48dbfb, #ff9ff3);
      background-size: 300% 300%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradientShift 4s ease infinite;
    }
    @keyframes gradientShift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    #intro .subtitle {
      font-size: clamp(1rem, 3vw, 1.4rem);
      margin-top: 1rem;
      opacity: 0.8;
      text-align: center;
    }
    .start-btn {
      margin-top: 2.5rem;
      padding: 1rem 2.5rem;
      font-size: clamp(1rem, 3vw, 1.3rem);
      font-family: 'Nunito', sans-serif;
      font-weight: 700;
      border: none;
      border-radius: 50px;
      background: linear-gradient(135deg, #6c5ce7, #a29bfe);
      color: #fff;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 25px rgba(108, 92, 231, 0.5);
      animation: pulse 2s ease-in-out infinite;
    }
    .start-btn:hover, .start-btn:active {
      transform: scale(1.05);
      box-shadow: 0 6px 35px rgba(108, 92, 231, 0.7);
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.04); }
    }

    /* ===== GAME ===== */
    #game { justify-content: flex-start; padding-top: 1rem; }

    .game-header {
      text-align: center;
      z-index: 20;
      position: relative;
    }
    .game-header h2 {
      font-family: 'Comfortaa', sans-serif;
      font-size: clamp(1.2rem, 4vw, 1.8rem);
      margin-bottom: 0.5rem;
    }
    .progress {
      font-size: clamp(0.9rem, 2.5vw, 1.1rem);
      opacity: 0.7;
    }

    .balloon-area {
      position: fixed;
      inset: 0;
      z-index: 15;
    }

    .balloon {
      position: absolute;
      width: clamp(70px, 18vw, 95px);
      height: clamp(84px, 22vw, 114px);
      cursor: pointer;
      filter: drop-shadow(0 4px 15px rgba(0,0,0,0.4));
      z-index: 15;
      transition: none;
      touch-action: manipulation;
    }
    .balloon:active { filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3)); }

    .balloon-body {
      width: 100%;
      height: 100%;
      border-radius: 50% 50% 50% 50% / 55% 55% 45% 45%;
      position: relative;
      overflow: hidden;
    }
    .balloon-body::before {
      content: '';
      position: absolute;
      top: 15%;
      left: 20%;
      width: 25%;
      height: 35%;
      background: rgba(255,255,255,0.35);
      border-radius: 50%;
      transform: rotate(-30deg);
    }
    .balloon-knot {
      width: 12px;
      height: 12px;
      margin: -2px auto 0;
      clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
    }
    .balloon-string {
      width: 2px;
      height: 30px;
      margin: 0 auto;
      background: rgba(255,255,255,0.3);
      border-radius: 0 0 2px 2px;
    }

    .balloon.popping {
      animation: pop 0.35s ease-out forwards;
      pointer-events: none;
    }
    @keyframes pop {
      0% { transform: scale(1); opacity: 1; }
      30% { transform: scale(1.5); opacity: 0.7; }
      100% { transform: scale(0); opacity: 0; }
    }

    .pop-particles {
      position: fixed;
      pointer-events: none;
      z-index: 25;
    }
    .pop-particle {
      position: absolute;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      animation: particleFly 0.7s ease-out forwards;
    }
    @keyframes particleFly {
      0% { transform: translate(0, 0) scale(1); opacity: 1; }
      100% { transform: translate(var(--tx), var(--ty)) scale(0); opacity: 0; }
    }

    /* ===== PHOTO + TYPEWRITER OVERLAY ===== */
    .reveal-overlay {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #0a0a2e;
      animation: overlayIn 0.3s ease-out;
    }
    @keyframes overlayIn {
      0% { opacity: 0; }
      100% { opacity: 1; }
    }
    .reveal-overlay .reveal-photo {
      width: clamp(260px, 75vw, 400px);
      max-height: 55vh;
      object-fit: cover;
      border-radius: 20px;
      box-shadow: 0 10px 50px rgba(0,0,0,0.6);
      border: 3px solid rgba(255,255,255,0.15);
      animation: photoZoom 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes photoZoom {
      0% { transform: scale(0.3); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
    .reveal-overlay .msg-text {
      font-family: 'Comfortaa', sans-serif;
      font-size: clamp(1.2rem, 4.5vw, 1.8rem);
      text-align: center;
      line-height: 1.5;
      max-width: 85vw;
      color: #fff;
      margin-top: 1.5rem;
      min-height: 2.5em;
      text-shadow: 0 0 20px rgba(255,255,255,0.3);
    }
    .reveal-overlay .msg-text .cursor {
      display: inline-block;
      width: 3px;
      height: 1.1em;
      background: #feca57;
      margin-left: 2px;
      vertical-align: text-bottom;
      animation: blink 0.6s step-end infinite;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* ===== FINAL ===== */
    #final {
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 2rem 1.5rem;
      justify-content: flex-start;
    }
    .age-badge {
      font-family: 'Comfortaa', sans-serif;
      font-size: clamp(4rem, 15vw, 8rem);
      font-weight: 900;
      background: linear-gradient(135deg, #feca57, #ff6b6b);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 30px rgba(254, 202, 87, 0.5));
      animation: glowPulse 2s ease-in-out infinite alternate;
      margin-top: 1.5rem;
    }
    @keyframes glowPulse {
      0% { filter: drop-shadow(0 0 20px rgba(254, 202, 87, 0.3)); }
      100% { filter: drop-shadow(0 0 40px rgba(254, 202, 87, 0.7)); }
    }
    #final h2 {
      font-family: 'Comfortaa', sans-serif;
      font-size: clamp(1.6rem, 6vw, 2.8rem);
      text-align: center;
      margin: 1rem 0;
      background: linear-gradient(135deg, #ff6b6b, #feca57, #48dbfb);
      background-size: 300% 300%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradientShift 4s ease infinite;
    }
    .letter {
      max-width: 560px;
      text-align: center;
      font-size: clamp(1rem, 2.8vw, 1.2rem);
      line-height: 1.8;
      opacity: 0;
      animation: fadeUp 1s ease-out 0.5s forwards;
      margin-bottom: 2rem;
      color: rgba(255,255,255,0.9);
    }
    .letter p { margin-bottom: 1rem; }
    .letter .signature {
      margin-top: 1.5rem;
      font-style: italic;
      opacity: 0.8;
    }
    .letter .highlight {
      color: #feca57;
      font-weight: 700;
    }
    @keyframes fadeUp {
      0% { opacity: 0; transform: translateY(30px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    .heart-row {
      font-size: 2rem;
      margin: 1rem 0;
      animation: fadeUp 1s ease-out 1s forwards;
      opacity: 0;
    }
    .restart-btn {
      margin: 1.5rem 0 3rem;
      padding: 0.7rem 2rem;
      font-family: 'Nunito', sans-serif;
      font-size: 1rem;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 50px;
      background: transparent;
      color: rgba(255,255,255,0.5);
      cursor: pointer;
      opacity: 0;
      animation: fadeUp 0.6s ease-out 2s forwards;
    }
    .restart-btn:hover { background: rgba(255,255,255,0.1); }
  </style>
</head>
<body>
  <canvas id="confetti"></canvas>
  <div class="stars" id="stars"></div>

  <!-- INTRO -->
  <div class="screen" id="intro">
    <h1>Привет, Джамил!</h1>
    <p class="subtitle">Тебя ждёт кое-что особенное...</p>
    <button class="start-btn" id="startBtn">Начать 🚀</button>
  </div>

  <!-- GAME -->
  <div class="screen hidden" id="game">
    <div class="game-header">
      <h2>Лопни шарик! 🎈</h2>
      <p class="progress"><span id="popped">0</span> / 11</p>
    </div>
    <div class="balloon-area" id="balloonArea"></div>
  </div>

  <!-- FINAL -->
  <div class="screen hidden" id="final">
    <div class="age-badge">11</div>
    <h2>С Днём Рождения, Джамил!</h2>
    <div class="letter">
      <p>Дорогой Джамил!</p>
      <p>Тебе сегодня <span class="highlight">11 лет</span>, и я хочу сказать тебе кое-что важное.</p>
      <p>Ты не просто подрос на год — ты стал <span class="highlight">настоящим старшим братом</span>. Мехри и Марьям очень повезло, что у них есть ты. Ты заботишься о них, защищаешь их и показываешь им пример каждый день. Это не каждый взрослый умеет, а тебе всего 11!</p>
      <p>Я <span class="highlight">горжусь тобой</span>. Горжусь тем, какой ты добрый, какой ты сильный, и каким человеком ты становишься. У тебя впереди столько всего удивительного, и я знаю — ты со всем справишься.</p>
      <p>Пусть этот год будет самым лучшим. Пусть сбудутся все твои мечты. А я всегда рядом.</p>
      <p class="signature">С любовью,<br/>твой дядя Риад ❤️</p>
    </div>
    <div class="heart-row">🎂 🎁 🎉 🎊 ⭐</div>
    <button class="restart-btn" id="restartBtn">Ещё раз 🔄</button>
  </div>

  <script>
    // ===== Stars =====
    const starsEl = document.getElementById('stars');
    for (let i = 0; i < 80; i++) {
      const s = document.createElement('span');
      const size = Math.random() * 3 + 1;
      Object.assign(s.style, {
        width: size + 'px', height: size + 'px',
        top: Math.random() * 100 + '%',
        left: Math.random() * 100 + '%',
        '--d': (Math.random() * 3 + 2) + 's',
        animationDelay: Math.random() * 3 + 's',
      });
      starsEl.appendChild(s);
    }

    // ===== Confetti =====
    const canvas = document.getElementById('confetti');
    const ctx = canvas.getContext('2d');
    let confettiPieces = [];

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    function launchConfetti(duration = 4000) {
      const end = Date.now() + duration;
      const colors = ['#ff6b6b','#feca57','#48dbfb','#ff9ff3','#6c5ce7','#55efc4','#fd79a8'];
      function addBatch() {
        if (Date.now() > end) return;
        for (let i = 0; i < 8; i++) {
          confettiPieces.push({
            x: Math.random() * canvas.width, y: -10,
            w: Math.random() * 10 + 5, h: Math.random() * 6 + 3,
            color: colors[Math.floor(Math.random() * colors.length)],
            vx: (Math.random() - 0.5) * 4, vy: Math.random() * 3 + 2,
            rot: Math.random() * 360, rv: (Math.random() - 0.5) * 8,
          });
        }
        requestAnimationFrame(addBatch);
      }
      addBatch();
      if (!confettiDrawing) drawConfetti();
    }
    let confettiDrawing = false;
    function drawConfetti() {
      confettiDrawing = true;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      confettiPieces = confettiPieces.filter(p => p.y < canvas.height + 20);
      for (const p of confettiPieces) {
        p.x += p.vx; p.y += p.vy; p.vy += 0.04; p.rot += p.rv;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot * Math.PI / 180);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
        ctx.restore();
      }
      if (confettiPieces.length > 0) {
        requestAnimationFrame(drawConfetti);
      } else {
        confettiDrawing = false;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }

    // ===== Pop sound via Web Audio =====
    let audioCtx;
    function playPop() {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(600, audioCtx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(150, audioCtx.currentTime + 0.15);
      gain.gain.setValueAtTime(0.4, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.15);
      osc.start(audioCtx.currentTime);
      osc.stop(audioCtx.currentTime + 0.15);

      const noise = audioCtx.createBufferSource();
      const buf = audioCtx.createBuffer(1, audioCtx.sampleRate * 0.08, audioCtx.sampleRate);
      const data = buf.getChannelData(0);
      for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * 0.3;
      noise.buffer = buf;
      const ng = audioCtx.createGain();
      noise.connect(ng);
      ng.connect(audioCtx.destination);
      ng.gain.setValueAtTime(0.3, audioCtx.currentTime);
      ng.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.08);
      noise.start(audioCtx.currentTime);
    }

    // ===== Victory chime =====
    function playChime() {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      const t = audioCtx.currentTime;
      const notes = [523, 659, 784, 1047];
      notes.forEach((freq, i) => {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(freq, t + i * 0.12);
        gain.gain.setValueAtTime(0, t);
        gain.gain.setValueAtTime(0.25, t + i * 0.12);
        gain.gain.exponentialRampToValueAtTime(0.001, t + i * 0.12 + 0.4);
        osc.start(t + i * 0.12);
        osc.stop(t + i * 0.12 + 0.5);
      });
    }

    function playFanfare() {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      const t = audioCtx.currentTime;
      const notes = [523, 523, 659, 784, 659, 784, 1047];
      const times = [0, 0.15, 0.3, 0.45, 0.65, 0.8, 0.95];
      const durs =  [0.12, 0.12, 0.12, 0.15, 0.12, 0.12, 0.6];
      notes.forEach((freq, i) => {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(freq, t + times[i]);
        gain.gain.setValueAtTime(0, t);
        gain.gain.setValueAtTime(0.3, t + times[i]);
        gain.gain.exponentialRampToValueAtTime(0.001, t + times[i] + durs[i] + 0.3);
        osc.start(t + times[i]);
        osc.stop(t + times[i] + durs[i] + 0.4);
      });
    }

    // ===== Data =====
    const messages = [
      "Тебе 11! Ты растёшь так быстро! 🌟",
      "Ты самый лучший старший брат!",
      "Мехри и Марьям гордятся тобой! 💜",
      "Ты заботишься о сёстрах как герой 🛡️",
      "Мама и Папа гордятся тобой! 🥹",
      "Дядя Риад гордится тобой! 💪",
      "Ты добрый и сильный 🛡️",
      "Ты умный и смелый 🧠",
      "Ты делаешь всех вокруг счастливее ☀️",
      "Ты особенный человек ⭐",
      "А теперь... сюрприз! 🎁",
    ];
    const photos = [
      "/jamil/alone1.jpeg",
      "/jamil/alone2.jpeg",
      "/jamil/siblings.jpeg",
      "/jamil/siblings3.jpeg",
      "/jamil/family.jpeg",
      "/jamil/riad.jpeg",
      "/jamil/alone.jpeg",
      "/jamil/all.jpeg",
      "/jamil/alone4.jpeg",
      "/jamil/samir.jpeg",
      "/jamil/nara.jpeg",
    ];
    const balloonColors = [
      '#ff6b6b','#feca57','#48dbfb','#ff9ff3','#6c5ce7',
      '#55efc4','#fd79a8','#a29bfe','#fdcb6e','#00cec9','#e17055',
    ];

    // Preload images
    photos.forEach(src => { const img = new Image(); img.src = src; });

    let poppedCount = 0;
    let balloonAnimId = null;

    function show(id) { document.getElementById(id).classList.remove('hidden'); }
    function hide(id) { document.getElementById(id).classList.add('hidden'); }

    function lighten(hex) {
      const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
      return `rgb(${Math.min(255,r+60)},${Math.min(255,g+60)},${Math.min(255,b+60)})`;
    }

    function spawnParticles(x, y, color) {
      const container = document.createElement('div');
      container.className = 'pop-particles';
      container.style.left = x + 'px';
      container.style.top = y + 'px';
      for (let i = 0; i < 12; i++) {
        const p = document.createElement('div');
        p.className = 'pop-particle';
        const angle = (Math.PI * 2 / 12) * i;
        const dist = Math.random() * 60 + 30;
        p.style.background = color;
        p.style.setProperty('--tx', Math.cos(angle) * dist + 'px');
        p.style.setProperty('--ty', Math.sin(angle) * dist + 'px');
        container.appendChild(p);
      }
      document.body.appendChild(container);
      setTimeout(() => container.remove(), 800);
    }

    // ===== Photo reveal + typewriter =====
    function showReveal(photoSrc, msg) {
      return new Promise(resolve => {
        const overlay = document.createElement('div');
        overlay.className = 'reveal-overlay';

        const img = document.createElement('img');
        img.className = 'reveal-photo';
        img.src = photoSrc;
        overlay.appendChild(img);

        const textEl = document.createElement('div');
        textEl.className = 'msg-text';
        overlay.appendChild(textEl);

        document.body.appendChild(overlay);
        playChime();

        // Start typewriter after photo animation
        setTimeout(() => {
          const cursor = document.createElement('span');
          cursor.className = 'cursor';
          textEl.appendChild(cursor);

          let i = 0;
          const chars = [...msg];
          function type() {
            if (i < chars.length) {
              cursor.before(document.createTextNode(chars[i]));
              i++;
              setTimeout(type, 45);
            } else {
              setTimeout(() => {
                overlay.style.transition = 'opacity 0.5s';
                overlay.style.opacity = '0';
                setTimeout(() => { overlay.remove(); resolve(); }, 500);
              }, 1400);
            }
          }
          type();
        }, 700);
      });
    }

    // ===== Moving balloon =====
    function spawnBalloon(index) {
      const area = document.getElementById('balloonArea');
      area.innerHTML = '';
      if (balloonAnimId) { cancelAnimationFrame(balloonAnimId); balloonAnimId = null; }

      const color = balloonColors[index];
      const balloon = document.createElement('div');
      balloon.className = 'balloon';
      balloon.innerHTML = `
        <div class="balloon-body" style="background: radial-gradient(circle at 35% 35%, ${lighten(color)}, ${color})"></div>
        <div class="balloon-knot" style="background: ${color}"></div>
        <div class="balloon-string"></div>
      `;

      const bw = Math.min(95, window.innerWidth * 0.18);
      const bh = bw * 1.2;
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const padTop = 80;
      const padBottom = 40;

      let x = Math.random() * (vw - bw);
      let y = padTop + Math.random() * (vh - bh - padTop - padBottom);
      const baseSpeed = 1.5 + index * 0.25;
      let angle = Math.random() * Math.PI * 2;
      let vx = Math.cos(angle) * baseSpeed;
      let vy = Math.sin(angle) * baseSpeed;
      let wobbleT = 0;

      balloon.style.left = x + 'px';
      balloon.style.top = y + 'px';
      area.appendChild(balloon);

      let popped = false;

      function animate() {
        if (popped) return;
        wobbleT += 0.03;
        x += vx + Math.sin(wobbleT * 2) * 0.5;
        y += vy + Math.cos(wobbleT * 1.5) * 0.4;

        if (x <= 0 || x >= vw - bw) { vx *= -1; x = Math.max(0, Math.min(x, vw - bw)); }
        if (y <= padTop || y >= vh - bh - padBottom) { vy *= -1; y = Math.max(padTop, Math.min(y, vh - bh - padBottom)); }

        if (Math.random() < 0.008) {
          angle += (Math.random() - 0.5) * 1.2;
          vx = Math.cos(angle) * baseSpeed;
          vy = Math.sin(angle) * baseSpeed;
        }

        balloon.style.left = x + 'px';
        balloon.style.top = y + 'px';
        balloonAnimId = requestAnimationFrame(animate);
      }
      animate();

      function onPop(e) {
        if (popped) return;
        e.preventDefault();
        popped = true;
        cancelAnimationFrame(balloonAnimId);
        balloon.classList.add('popping');
        playPop();

        const rect = balloon.getBoundingClientRect();
        spawnParticles(rect.left + rect.width/2, rect.top + rect.height/2, color);

        poppedCount++;
        document.getElementById('popped').textContent = poppedCount;

        setTimeout(async () => {
          balloon.remove();
          await showReveal(photos[index], messages[index]);

          if (poppedCount >= 11) {
            hide('game');
            show('final');
            launchConfetti(5000);
            playFanfare();
          } else {
            spawnBalloon(poppedCount);
          }
        }, 400);
      }

      balloon.addEventListener('click', onPop);
      balloon.addEventListener('touchend', onPop);
    }

    // ===== Start =====
    document.getElementById('startBtn').addEventListener('click', () => {
      hide('intro');
      show('game');
      poppedCount = 0;
      document.getElementById('popped').textContent = '0';
      launchConfetti(1500);
      setTimeout(() => spawnBalloon(0), 600);
    });

    // ===== Restart =====
    document.getElementById('restartBtn').addEventListener('click', () => {
      hide('final');
      show('intro');
    });
  </script>
</body>
</html>
