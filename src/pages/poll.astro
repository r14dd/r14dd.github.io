---
// Standalone classroom-poll phone page (QR target).
// Deliberately does NOT use BaseLayout — that inlines ~3000 lines of portfolio
// CSS. We copy only the viewport meta, the three Manrope @font-face blocks and
// the manrope-latin.woff2 preload, then force a calm dark theme to match riad.cc.
// The page never learns the option text or vote counts: it only sends A/B/C/D.
---
<!DOCTYPE html>
<html lang="en" translate="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#050505" />
    <title>Live Poll</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href="/fonts/manrope-latin.woff2" as="font" type="font/woff2" crossorigin />

    <style is:global>
      @font-face { font-family: 'Manrope'; font-style: normal; font-weight: 200 800; font-display: swap; src: url(/fonts/manrope-cyrillic.woff2) format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
      @font-face { font-family: 'Manrope'; font-style: normal; font-weight: 200 800; font-display: swap; src: url(/fonts/manrope-latin-ext.woff2) format('woff2'); unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF; }
      @font-face { font-family: 'Manrope'; font-style: normal; font-weight: 200 800; font-display: swap; src: url(/fonts/manrope-latin.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }

      :root {
        color-scheme: dark;
        --bg: #050505;
        --text: #eeeeee;
        --text-soft: #a1a1a1;
        --muted: #777777;
        --accent: #c9a55a;
        --accent-rgb: 201, 165, 90;
        --border: rgba(255, 255, 255, 0.10);
        --surface: rgba(255, 255, 255, 0.035);
        --ease-spring: cubic-bezier(0.16, 1, 0.3, 1);
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        min-height: 100%;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Manrope', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        min-height: 100svh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        /* Respect notches; comfortable breathing room. */
        padding:
          calc(env(safe-area-inset-top) + 32px)
          calc(env(safe-area-inset-right) + 22px)
          calc(env(safe-area-inset-bottom) + 28px)
          calc(env(safe-area-inset-left) + 22px);
      }

      .shell {
        width: 100%;
        max-width: 460px;
        margin: auto 0;
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      .masthead {
        display: flex;
        flex-direction: column;
        gap: 10px;
        text-align: center;
      }
      .eyebrow {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--accent);
      }
      .heading {
        margin: 0;
        font-size: 1.9rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.1;
      }
      .subhead {
        margin: 0;
        font-size: 0.98rem;
        line-height: 1.5;
        color: var(--text-soft);
      }

      .options {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }

      .poll-option {
        position: relative;
        appearance: none;
        -webkit-appearance: none;
        width: 100%;
        min-height: 72px;
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 16px 22px;
        font-family: inherit;
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--text);
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 16px;
        cursor: pointer;
        text-align: left;
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
        transition:
          transform 140ms var(--ease-spring),
          border-color 160ms ease,
          background-color 160ms ease,
          opacity 160ms ease;
      }
      .poll-option .letter {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--accent);
        background: rgba(var(--accent-rgb), 0.12);
        border: 1px solid rgba(var(--accent-rgb), 0.28);
      }
      .poll-option .cue {
        font-size: 1rem;
        font-weight: 500;
        color: var(--text-soft);
      }

      /* Press feedback (mobile has no :hover — use :active). */
      .poll-option:active:not(:disabled) {
        transform: scale(0.975);
        border-color: rgba(var(--accent-rgb), 0.55);
      }
      .poll-option:focus-visible {
        outline: 3px solid rgba(var(--accent-rgb), 0.65);
        outline-offset: 2px;
      }

      .poll-option.chosen {
        border-color: var(--accent);
        background: rgba(var(--accent-rgb), 0.14);
      }
      .poll-option.chosen .letter {
        color: #050505;
        background: var(--accent);
        border-color: var(--accent);
      }
      .poll-option.chosen .cue { color: var(--accent); }

      .poll-option:disabled {
        cursor: default;
      }
      /* Dim only the unchosen options once a vote is locked in. */
      .poll-option:disabled:not(.chosen) {
        opacity: 0.4;
      }

      .status {
        min-height: 1.5em;
        text-align: center;
        font-size: 1.02rem;
        font-weight: 500;
        line-height: 1.5;
        color: var(--text-soft);
        transition: color 160ms ease;
      }
      .status[data-tone="ok"] { color: var(--accent); }
      .status[data-tone="warn"] { color: #e0a96d; }
      .status[data-tone="error"] { color: #e2725b; }

      .foot {
        text-align: center;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }

      /* Force-hide elements with [hidden]; class display:flex would otherwise win. */
      [hidden] { display: none !important; }

      /* ── Camera-less fallback: type the code shown on the projector ── */
      .join {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .join__label {
        font-size: 1.02rem;
        font-weight: 500;
        line-height: 1.5;
        text-align: center;
        color: var(--text-soft);
      }
      .join__input {
        appearance: none;
        -webkit-appearance: none;
        width: 100%;
        min-height: 72px;
        padding: 16px 22px;
        font-family: inherit;
        font-size: 1.5rem;
        font-weight: 600;
        text-align: center;
        letter-spacing: 0.04em;
        color: var(--text);
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 16px;
        touch-action: manipulation;
        transition: border-color 160ms ease, background-color 160ms ease;
      }
      .join__input::placeholder { color: var(--muted); font-weight: 500; }
      .join__input:focus {
        outline: none;
        border-color: var(--accent);
        background: rgba(var(--accent-rgb), 0.10);
      }
      .join__input:focus-visible {
        outline: 3px solid rgba(var(--accent-rgb), 0.65);
        outline-offset: 2px;
      }
      .join__btn {
        appearance: none;
        -webkit-appearance: none;
        width: 100%;
        min-height: 72px;
        font-family: inherit;
        font-size: 1.35rem;
        font-weight: 700;
        color: #050505;
        background: var(--accent);
        border: 1.5px solid var(--accent);
        border-radius: 16px;
        cursor: pointer;
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
        transition: transform 140ms var(--ease-spring), opacity 160ms ease;
      }
      .join__btn:active { transform: scale(0.975); }
      .join__btn:focus-visible {
        outline: 3px solid rgba(var(--accent-rgb), 0.65);
        outline-offset: 2px;
      }

      @media (prefers-reduced-motion: reduce) {
        .poll-option { transition: none; }
        .poll-option:active:not(:disabled) { transform: none; }
        .join__btn { transition: none; }
        .join__btn:active { transform: none; }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="masthead">
        <span class="eyebrow">Live Poll</span>
        <h1 class="heading">Tap your answer</h1>
        <p class="subhead" id="prompt">The question is on the screen.</p>
      </header>

      <div class="options" id="options">
        <button class="poll-option" type="button" data-choice="A" aria-label="Vote for option A">
          <span class="letter" aria-hidden="true">A</span>
          <span class="cue">Option A</span>
        </button>
        <button class="poll-option" type="button" data-choice="B" aria-label="Vote for option B">
          <span class="letter" aria-hidden="true">B</span>
          <span class="cue">Option B</span>
        </button>
        <button class="poll-option" type="button" data-choice="C" aria-label="Vote for option C">
          <span class="letter" aria-hidden="true">C</span>
          <span class="cue">Option C</span>
        </button>
        <button class="poll-option" type="button" data-choice="D" aria-label="Vote for option D">
          <span class="letter" aria-hidden="true">D</span>
          <span class="cue">Option D</span>
        </button>
      </div>

      <form class="join" id="join" hidden>
        <label class="join__label" for="join-code">Enter the code shown on screen</label>
        <input
          class="join__input"
          id="join-code"
          name="code"
          type="text"
          inputmode="text"
          autocapitalize="off"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          enterkeyhint="go"
          placeholder="poll code"
          aria-describedby="status"
        />
        <button class="join__btn" type="submit">Join</button>
      </form>

      <p class="status" id="status" role="status" aria-live="polite"></p>

      <footer class="foot">riad.cc</footer>
    </main>

    <script is:inline>
      (function () {
        var params = new URLSearchParams(location.search);
        var session = params.get('s');

        // Worker base by hostname — must equal the prod value the slide engine uses.
        var WORKER = location.hostname === 'riad.cc'
          ? 'https://poll-api.riad-mrv.workers.dev'
          : 'http://' + location.hostname + ':8787';

        // LAN http (e.g. a phone hitting 192.168.x.x) is NOT a secure context, so
        // crypto.randomUUID is undefined there — build a v4 UUID from getRandomValues.
        function fallbackUuid() {
          var b = crypto.getRandomValues(new Uint8Array(16));
          b[6] = (b[6] & 0x0f) | 0x40;
          b[8] = (b[8] & 0x3f) | 0x80;
          var h = [];
          for (var i = 0; i < 16; i++) h.push(b[i].toString(16).padStart(2, '0'));
          var s = h.join('');
          return s.slice(0, 8) + '-' + s.slice(8, 12) + '-' + s.slice(12, 16) + '-' + s.slice(16, 20) + '-' + s.slice(20);
        }

        var voterId = localStorage.getItem('poll-voter') || ((crypto.randomUUID && crypto.randomUUID()) || fallbackUuid());
        localStorage.setItem('poll-voter', voterId);

        var statusEl = document.getElementById('status');
        var promptEl = document.getElementById('prompt');
        var buttons = Array.prototype.slice.call(document.querySelectorAll('.poll-option'));

        // The slide's QR passes &n= with this poll's option count, so a 2-choice
        // poll doesn't show dead C/D buttons. Absent/invalid -> keep all four.
        var optionCount = parseInt(params.get('n'), 10);
        if (optionCount >= 2 && optionCount < 4) {
          buttons.slice(optionCount).forEach(function (b) { b.remove(); });
          buttons = buttons.slice(0, optionCount);
        }

        var votedKey = session ? ('poll-voted-' + session) : null;
        var inFlight = false;
        var pollOpen = true;     // assume open until /state says otherwise
        var roundLocked = false; // set when this round is capped (room full)
        var storedGen = null;    // last seen generation (re-vote detector)
        var pollTimer = null;

        function getVoted() { return votedKey ? localStorage.getItem(votedKey) : null; }

        function setStatus(msg, tone) {
          statusEl.textContent = msg || '';
          if (tone) statusEl.setAttribute('data-tone', tone);
          else statusEl.removeAttribute('data-tone');
        }

        function syncButtons() {
          var voted = getVoted();
          buttons.forEach(function (b) {
            var isChosen = !!voted && b.getAttribute('data-choice') === voted;
            b.classList.toggle('chosen', isChosen);
            b.disabled = !session || inFlight || !!voted || !pollOpen || roundLocked;
          });
        }

        function vote(choice) {
          if (!session || inFlight || getVoted()) return;
          inFlight = true;
          syncButtons();
          setStatus('Sending your answer…');

          fetch(WORKER + '/vote', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ session: session, choice: choice, voterId: voterId }),
            signal: AbortSignal.timeout(8000)
          }).then(function (res) {
            return res.json().catch(function () { return {}; }).then(function (data) {
              return { status: res.status, ok: res.ok, data: data || {} };
            });
          }).then(function (r) {
            inFlight = false;

            // Already voted (lost-response recovery) — treat as success.
            if (r.status === 409) {
              var c409 = r.data.choice || choice;
              localStorage.setItem(votedKey, c409);
              syncButtons();
              setStatus('Already counted — you chose ' + c409 + '.', 'ok');
              return;
            }

            if (r.ok) {
              // Voting closed: the worker returns 200 {ok:false, closed:true}.
              // Don't record the vote or lock the student — let them vote when
              // the instructor reopens the round.
              if (r.data.closed || r.data.ok === false) {
                pollOpen = false;
                syncButtons();
                setStatus('Voting is closed right now.', 'warn');
                return;
              }
              // Room full: the vote was not counted.
              if (r.data.capped) {
                roundLocked = true;
                syncButtons();
                setStatus('The room is full (60 votes in). Your answer could not be counted.', 'warn');
                return;
              }
              var c = r.data.choice || choice;
              localStorage.setItem(votedKey, c);
              syncButtons();
              setStatus('Vote recorded — you chose ' + c + '.', 'ok');
              return;
            }

            // Voting closed (worker may signal via flag/error text).
            if (r.data.closed || /clos/i.test(r.data.error || '')) {
              pollOpen = false;
              syncButtons();
              setStatus('Voting is closed right now.', 'warn');
              return;
            }

            // Anything else — let them retry (idempotent via voterId).
            syncButtons();
            setStatus('Could not record that — tap to try again.', 'error');
          }).catch(function () {
            // Timeout / network. Retrying is safe: the voterId de-dupes server-side.
            inFlight = false;
            syncButtons();
            setStatus('Network hiccup — tap to try again.', 'error');
          });
        }

        buttons.forEach(function (b) {
          b.addEventListener('click', function () {
            vote(b.getAttribute('data-choice'));
          });
        });

        // ── Re-vote rounds: poll /state (counts-free) and reset when generation grows.
        function applyOpenState(open) {
          var voted = getVoted();
          var wasOpen = pollOpen;
          pollOpen = open;
          if (voted || inFlight || roundLocked) { syncButtons(); return; }
          if (!open) {
            syncButtons();
            setStatus('Hang tight — voting isn’t open yet.');
          } else if (!wasOpen) {
            syncButtons();
            setStatus('Tap your answer above.');
          } else {
            syncButtons();
          }
        }

        function pollState() {
          if (!session || document.hidden) return;
          fetch(WORKER + '/state?s=' + encodeURIComponent(session), {
            signal: AbortSignal.timeout(8000)
          }).then(function (res) {
            if (!res.ok) return null;
            return res.json();
          }).then(function (data) {
            if (!data) return;
            var gen = data.generation;
            var open = data.open !== false; // default open

            if (storedGen === null) {
              storedGen = (typeof gen === 'number') ? gen : 0;
            } else if (typeof gen === 'number' && gen > storedGen) {
              // New round — clear our vote and reset to votable.
              storedGen = gen;
              roundLocked = false;
              if (votedKey) localStorage.removeItem(votedKey);
              pollOpen = open;
              syncButtons();
              setStatus(open ? 'New round — tap your answer.' : 'Hang tight — voting isn’t open yet.');
              return;
            }
            applyOpenState(open);
          }).catch(function () { /* transient — ignore, try again next tick */ });
        }

        // ── Boot ──────────────────────────────────────────────────────────
        // No ?s= in the URL — show a typed code entry for camera-less students.
        // Submitting navigates to ?s=<code>, which reloads this page with a
        // session and re-runs every code path below untouched. (A typed code
        // carries no &n=, so all four option buttons show — an OK fallback.)
        if (!session) {
          var optionsEl = document.getElementById('options');
          var joinForm = document.getElementById('join');
          var joinInput = document.getElementById('join-code');
          var headingEl = document.querySelector('.heading');

          if (optionsEl) optionsEl.hidden = true;
          if (headingEl) headingEl.textContent = 'Join the poll';
          promptEl.textContent = 'No poll has loaded on this device yet.';
          if (joinForm) joinForm.hidden = false;
          setStatus('Waiting for the instructor to start a poll.');

          if (joinForm) {
            joinForm.addEventListener('submit', function (e) {
              e.preventDefault();
              var code = (joinInput.value || '').trim().toLowerCase();
              if (!code) {
                setStatus('Type the code shown on screen, then tap Join.', 'warn');
                joinInput.focus();
                return;
              }
              setStatus('Joining…');
              location.search = '?s=' + encodeURIComponent(code);
            });
          }
          return;
        }

        var prior = getVoted();
        if (prior) {
          syncButtons();
          setStatus('Vote recorded — you chose ' + prior + '.', 'ok');
        } else {
          syncButtons();
          setStatus('Tap your answer above.');
        }

        pollState();
        pollTimer = setInterval(pollState, 3000);

        // Catch up immediately when the phone wakes / tab refocuses.
        document.addEventListener('visibilitychange', function () {
          if (document.visibilityState === 'visible') pollState();
        });
      })();
    </script>
  </body>
</html>
